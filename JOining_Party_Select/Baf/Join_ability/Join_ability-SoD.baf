IF
	Global("JO_JOIN_CAMPAIGN_SoD","MYAREA",0)
THEN
	RESPONSE #100
		SetGlobal("JO_JOIN_CAMPAIGN_BANTER","GLOBAL",2)
		ActionOverride(Player1,ChangeAIScript("JO_JOINP",OVERRIDE))
		SetGlobal("JO_JOIN_CAMPAIGN","GLOBAL",2)
		SetGlobal("JO_JOIN_CAMPAIGN_EET","GLOBAL",%CAMPAIGN_SoD%)
		SetGlobal("JO_JOIN_CAMPAIGN_SoD","MYAREA",1)
END

