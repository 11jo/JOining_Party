///////////////////////////////////////////////////////////////////////////////

// SoD bdplayer.bcs set in bdintro.bcs
IF
	Global("JO_JOIN_CAMPAIGN","GLOBAL",2)
	HotKey(B)
	OR(2)
		INI("QAMODE",1)
		Global("BD_QAMODE","global",1)
THEN
	RESPONSE #100
		SetGlobal("JO_JOIN_CUTSCENE","GLOBAL",0)
		StartDialogOverride("bddebug",Myself)
END

// EET player1.bcs set in ar0602.bcs
IF
	Global("JO_JOIN_CAMPAIGN","GLOBAL",3)
	Global("JO_JOIN_Player1_DLG","ar0602",0)
THEN
	RESPONSE #100
		SetDialog("Player1")
		SetGlobal("JO_JOIN_Player1_DLG","ar0602",1)
END
