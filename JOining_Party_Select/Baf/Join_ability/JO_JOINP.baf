///////////////////////////////////////////////////////////////////////////////

// Check if traveler are in party

///////////////////////////////////////////////////////////////////////////////
// Variables :
	// JO_JOIN_TRAVELER_NUM (Check if a least one traveler is present)
// Special
	// REPLACE TRAVELER NumInParty (Expanded at installation by JOining_Party_Select_End.tph)
// Note :
	// Related to BD0120.bcs and maybe other transitions (see JOining_Party_Select_End.tph)
		// Disable the Loading Switch if no traveler are her
			// Related block in JO_JOINP
///////////////////////////////////////////////////////////////////////////////

IF
//
	Global("JO_JOIN_LOADING","GLOBAL",0) // Don't use this block at loading
	Global("JO_JOIN_RETURN_SLOT","GLOBAL",0)
	!Global("JO_JOIN_TRAVELER_NUM","GLOBAL",0)
//
//	REPLACE_TRAVELER_NumInParty
THEN
	RESPONSE #100
		SetGlobal("JO_JOIN_TRAVELER_NUM","GLOBAL",0) // If there is no traveler reste the global
		Continue()
END

///////////////////////////////////////////////////////////////////////////////

// JO_JOIN_BANTER_TIMER centralised for all travelers

///////////////////////////////////////////////////////////////////////////////
// Variables :
	// JO_JOIN_BANTER_TIMER (Timer for starting banter)
		// JO_JOIN_CUTSCENE (Deactive travelers for cutscene)
			// JO_NOJOIN (Check if no traveler is currently switching)
				// JO_JOIN_NEVER_BANTER (Prevent lauching banters)
					// JO_JOIN_Move_Around (Centralised orders for all travelers at once)
// Note :
	// See the "JO_JOIN_BANTER_TIMER" commented out in Baf/Banter_Dream (Was set individually for each travelers, to see what is the best way...)
///////////////////////////////////////////////////////////////////////////////

IF
	!Global("JO_JOIN_AREA_TRANSITION","GLOBAL",1)
//
	Global("JO_JOIN_LOADING","GLOBAL",0) // Don't use this block at loading
	!GlobalTimerNotExpired("JO_JOIN_BANTER_TIMER","LOCALS")
	!AreaCheck("JO2608")
	!Global("JO_JOIN_TRAVELER_NUM","GLOBAL",0) // Should prevent Loading switch if no traveler exists
//
		// ActionListEmpty()
	!ActuallyInCombat()
	!See([ENEMY])
	Global("JO_NOJOIN","GLOBAL",0)
	Global("JO_JOIN_CUTSCENE","GLOBAL",0)
THEN
	RESPONSE #100
		SetGlobalTimer("JO_JOIN_BANTER_TIMER","LOCALS",TWELVE_HOURS) // Reset timer
		DisplayString(Myself,~We have time for a little chat.~)
		SetGlobal("JO_JOIN_BANTER_TIMER","GLOBAL",1)
		Continue()
END

