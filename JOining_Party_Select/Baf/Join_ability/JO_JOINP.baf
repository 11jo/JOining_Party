	!AreaCheck("%Undercity_TempleofBhaal%")
	!AreaCheck("BD0120")
//
	!Global("JO_JOIN_AREA_TRANSITION","GLOBAL",0)
//
	!Global("JO_JOIN_BG1_TRANSITION","%Undercity_TempleofBhaal%",1)
THEN
	RESPONSE #100
		SetGlobal("JO_JOIN_AREA_TRANSITION","GLOBAL",0)
		SetGlobal("JO_JOIN_BG1_TRANSITION","%Undercity_TempleofBhaal%",1)
END

