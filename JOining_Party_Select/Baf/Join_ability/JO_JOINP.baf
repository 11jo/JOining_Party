// Player1 override script

///////////////////////////////////////////////////////////////////////////////

// Dev variable

///////////////////////////////////////////////////////////////////////////////

IF
	Global("JO_JOIN_DEV_MODE","GLOBAL",0)
THEN
	RESPONSE #100
		SetGlobal("JO_JOIN_DEV_MODE","GLOBAL",1)
END


///////////////////////////////////////////////////////////////////////////////

// Loading Switch

///////////////////////////////////////////////////////////////////////////////
// Variables :
	// JO_JOIN_LOADING (Launch Loading Switch script/CutSceneLite)
		// JO_JOIN_AREA (Check if current area is a master area)
			// JO_JOIN_FORCE_LOAD (Force the Loading Switch at will)
				// JO_JOIN_TRAVELER_NumInParty (Check if a least one traveler is present)
					// JO_JOIN_LOADING_PLAYER (Check if party member are deactivated)
						// JO_JOIN_BLOP (Dev test for no master area)
							// JO_JOIN_SWITCHING_ROOM (In case area is JO2608.are prevent to end loading switch prematurely)
///////////////////////////////////////////////////////////////////////////////

// If area ISN'T a master area, then go to the Switching Room.

// Secondary Loading Switch 1 // Special // SWITCHING_ROOM JO2608.ARE

IF
// 
	OR(2)
		OnCreation()
		Global("JO_JOIN_FORCE_LOAD","GLOBAL",1) // Force Loading Switch
	OR(2)
		!Global("JO_JOIN_AREA","MYAREA",1)  // Current area IS'NT a master area
		See([ENEMY])
// Dev
	!Global("JO_JOIN_BLOP","GLOBAL",1) // Dev test for no master area
// 
	!Global("JO_JOIN_TRAVELER_NumInParty","GLOBAL",0) // Should prevent Loading switch if no traveler exists
	Global("JO_JOIN_SWITCHING_ROOM","LOCALS",0)
THEN
	RESPONSE #100
		ClearAllActions()
		SetCutSceneLite(TRUE)
		CreateVisualEffectObject("JOBG402",Player1)
		SetGlobal("JO_JOIN_SWITCHING_ROOM","LOCALS",1) // We are in the Switching room
		FadeToColor([20.0],0)
		Wait(1)
		StorePartyLocations()
		FadeFromColor([30.0],0)
		ActionOverride(Player1,LeaveAreaLUA("JO2608","",[1570.1050],1))
		ActionOverride(Player2,LeaveAreaLUA("JO2608","",[1362.944],1))
		ActionOverride(Player3,LeaveAreaLUA("JO2608","",[1318.1106],1))
		ActionOverride(Player4,LeaveAreaLUA("JO2608","",[1530.955],1))
		ActionOverride(Player5,LeaveAreaLUA("JO2608","",[1398.1172],1))
		ActionOverride(Player6,LeaveAreaLUA("JO2608","",[1251.1065],1))
		LeaveAreaLUAPanic("JO2608","",[1570.1050],1)
		LeaveAreaLUA("JO2608","",[1570.1050],1)
		MultiPlayerSync()
		Wait(1)
		CreateVisualEffectObject("JOBG402",Player1)
		SetCutSceneLite(FALSE)
		Continue()
END

// If area IS a master area, then Loading Switch !

// Main Loading Switch 1

IF
// 
	OR(3)
		OnCreation()
		Global("JO_JOIN_FORCE_LOAD","GLOBAL",1) // Force Loading Switch
		Global("JO_JOIN_SWITCHING_ROOM","LOCALS",1)
	OR(2)
		Global("JO_JOIN_AREA","MYAREA",1) // Current area is a master area
		Global("JO_JOIN_BLOP","GLOBAL",1) // Dev test for no master area
	OR(2)
		!See([ENEMY])
		Global("JO_JOIN_BLOP","GLOBAL",1) // Dev test for See([ENEMY])
// 
	!Global("JO_JOIN_TRAVELER_NumInParty","GLOBAL",0) // Should prevent Loading switch if no traveler exists
THEN
	RESPONSE #100
		SetInterrupt(FALSE)
		ClearAllActions()
		MoveViewObject(Player1,INSTANT)
		SetGlobalTimer("JO_JOIN_BANTER_TIMER","LOCALS",ONE_HOUR)
		SetGlobal("JO_JOIN_LOADING_PLAYER","LOCALS",0)
		SetGlobal("JO_JOIN_LOAD","LOCALS",0)
		SetGlobal("JO_JOIN_FORCE_LOAD","GLOBAL",0)
		SetCutSceneLite(TRUE) // Prevent players to mess around when switch at loading.
		DisplayStringHead(Myself,~Travelers !~)
		SetGlobal("JO_JOIN_LOADING","GLOBAL",1)
		ChangeAIScript("JO_JOINL",OVERRIDE) // Go to JO_JOINL.baf
		SetInterrupt(TRUE)
		Continue()
END

// If area ISN'T a master area, this block come after // Main 1 // Loading Switch

// Secondary Loading Switch 3 // Special // SWITCHING_ROOM JO2608.ARE

IF
// 
	Global("JO_JOIN_SWITCHING_ROOM","LOCALS",2) // Set in JO_JOINL.baf
// 
	!GlobalGT("JO_JOIN_LOADING_PLAYER","LOCALS",0)
THEN
	RESPONSE #100
		DisplayStringHead(Myself,~Let's return to venture forth !!~)
		SetCutSceneLite(FALSE) // Prevent players to mess around when switch at loading.
		FadeToColor([20.0],0)
		CreateVisualEffectObject("JOBG402",Player1)
		Wait(1)
		RestorePartyLocations()
// 
		SetGlobal("JO_JOIN_SWITCHING_ROOM","LOCALS",0) // We are ready to leave the Switching Room
		MoveToOffset([1.-1])
		FadeFromColor([30.0],0)
		SmallWait(10)
		CreateVisualEffectObject("JOBG402",Player1)
END

///////////////////////////////////////////////////////////////////////////////

// Initialize

///////////////////////////////////////////////////////////////////////////////
// Variables :
	// JO_JOIN_PLAYER_INIT (At new game beginning add special ability to Charname)
		// JO_JOIN_SWEET_DREAM (Related to dream talks)
			// JO_JOIN_BANTER_TIMER (Related to banter talks)
///////////////////////////////////////////////////////////////////////////////

IF
	Global("JO_JOIN_PLAYER_INIT","LOCALS",0)
THEN
	RESPONSE #100
		AddSpecialAbility("jo_join") // Charname special ability
		SetGlobal("JO_JOIN_PLAYER_INIT","LOCALS",1)
		SetGlobalTimer("JO_JOIN_SWEET_DREAM","LOCALS",FOUR_HOURS) // TODO : Unused at the moment
		SetGlobalTimer("JO_JOIN_BANTER_TIMER","LOCALS",FOUR_HOURS)
		Continue()
END

///////////////////////////////////////////////////////////////////////////////

// PartySlot

///////////////////////////////////////////////////////////////////////////////
// Variables :
	// JO_JOIN_PARTYSLOT (Value is party member place in UI)
// Note :
	// Used to know what slot were who even when traveler
///////////////////////////////////////////////////////////////////////////////

// Check Player1 Slot

IF
	TriggerOverride(PartySlot1,InPartySlot(Myself,0))
	Global("JO_JOIN_PROTAGONIST","GLOBAL",0)
THEN
	RESPONSE #100
		SetGlobal("JO_JOIN_PROTAGONIST","GLOBAL",1)
		Continue()
		
END

IF
	!TriggerOverride(PartySlot1,InPartySlot(Myself,0))
	Global("JO_JOIN_PROTAGONIST","GLOBAL",1)
THEN
	RESPONSE #100
		SetGlobal("JO_JOIN_PROTAGONIST","GLOBAL",0)
		Continue()
END

// Check party Slot

IF
	Global("JO_JOIN_RETURN_SLOT","GLOBAL",0)
	InParty(PartySlot6)
	!TriggerOverride(PartySlot6,Global("JO_JOIN_PARTYSLOT","LOCALS",6))
THEN
	RESPONSE #100
		ActionOverride(PartySlot6,SetGlobal("JO_JOIN_PARTYSLOT","LOCALS",6))
		Continue()
END

IF
	Global("JO_JOIN_RETURN_SLOT","GLOBAL",0)
	InParty(PartySlot5)
	!TriggerOverride(PartySlot5,Global("JO_JOIN_PARTYSLOT","LOCALS",5))
THEN
	RESPONSE #100
		ActionOverride(PartySlot5,SetGlobal("JO_JOIN_PARTYSLOT","LOCALS",5))
		Continue()
END

IF
	Global("JO_JOIN_RETURN_SLOT","GLOBAL",0)
	InParty(PartySlot4)
	!TriggerOverride(PartySlot4,Global("JO_JOIN_PARTYSLOT","LOCALS",4))
THEN
	RESPONSE #100
		ActionOverride(PartySlot4,SetGlobal("JO_JOIN_PARTYSLOT","LOCALS",4))
		Continue()
END

IF
	Global("JO_JOIN_RETURN_SLOT","GLOBAL",0)
	InParty(PartySlot3)
	!TriggerOverride(PartySlot3,Global("JO_JOIN_PARTYSLOT","LOCALS",3))
THEN
	RESPONSE #100
		ActionOverride(PartySlot3,SetGlobal("JO_JOIN_PARTYSLOT","LOCALS",3))
		Continue()
END

IF
	Global("JO_JOIN_RETURN_SLOT","GLOBAL",0)
	InParty(PartySlot2)
	!TriggerOverride(PartySlot2,Global("JO_JOIN_PARTYSLOT","LOCALS",2))
THEN
	RESPONSE #100
		ActionOverride(PartySlot2,SetGlobal("JO_JOIN_PARTYSLOT","LOCALS",2))
		Continue()
END

IF
	Global("JO_JOIN_RETURN_SLOT","GLOBAL",0)
	InParty(PartySlot1)
	!TriggerOverride(PartySlot1,Global("JO_JOIN_PARTYSLOT","LOCALS",1))
THEN
	RESPONSE #100
		ActionOverride(PartySlot1,SetGlobal("JO_JOIN_PARTYSLOT","LOCALS",1))
		Continue()
END

///////////////////////////////////////////////////////////////////////////////

// Base

///////////////////////////////////////////////////////////////////////////////
// Variables :
	// JO_Myself_AllowDead (Replace InPartyAllowDead())
		// JO_Myself_InParty (Replace InParty())
			// JO_Myself_Valid (Replace IsValidForPartyDialogue())
///////////////////////////////////////////////////////////////////////////////

// !InPartyAllowDead()
IF
	!Global("JO_Myself_AllowDead","LOCALS",0)
	!InPartyAllowDead(Myself)
	Global("JO_JOIN_IS_TRAVELER","LOCALS",0)
THEN
	RESPONSE #100
		SetGlobal("JO_Myself_AllowDead","LOCALS",0)
		Continue()
END

// InPartyAllowDead()
IF
	Global("JO_Myself_AllowDead","LOCALS",0)
	OR(2)
		InPartyAllowDead(Myself)
		!Global("JO_JOIN_IS_TRAVELER","LOCALS",0)
THEN
	RESPONSE #100
		SetGlobal("JO_Myself_AllowDead","LOCALS",1)
		Continue()
END

// !InParty()
IF
	!Global("JO_Myself_InParty","LOCALS",0)
	!InParty(Myself)
	OR(2)
		Global("JO_JOIN_IS_TRAVELER","LOCALS",0)
		!Global("JO_JOIN_SLEEPING_DEAD","LOCALS",0)
THEN
	RESPONSE #100
		SetGlobal("JO_Myself_InParty","LOCALS",0)
		Continue()
END

// InParty()
IF
	Global("JO_Myself_InParty","LOCALS",0)
	OR(2)
		InParty(Myself)
		!Global("JO_JOIN_IS_TRAVELER","LOCALS",0)
	OR(2)
		InParty(Myself)
		Global("JO_JOIN_SLEEPING_DEAD","LOCALS",0)
THEN
	RESPONSE #100
		SetGlobal("JO_Myself_InParty","LOCALS",1)
		Continue()
END

// !Is(!If)ValidForPartyDialog(ue)
IF
	!Global("JO_Myself_Valid","LOCALS",0)
	!IsValidForPartyDialogue(Myself)
	OR(4)
		Global("JO_JOIN_IS_TRAVELER","LOCALS",0)
		!Global("JO_JOIN_SLEEPING_DEAD","LOCALS",0)
		StateCheck(Myself,CD_STATE_NOTVALID)
		!IsActive(Myself)
THEN
	RESPONSE #100
		SetGlobal("JO_Myself_Valid","LOCALS",0)
		Continue()
END

// Is(If)ValidForPartyDialog(ue)
IF
	Global("JO_Myself_Valid","LOCALS",0)
	Global("JO_JOIN_SLEEPING_DEAD","LOCALS",0)
	IsActive(Myself)
	OR(2)
		IsValidForPartyDialogue(Myself)
		!StateCheck(Myself,CD_STATE_NOTVALID)
	OR(2)
		InParty(Myself)
		!Global("JO_JOIN_IS_TRAVELER","LOCALS",0)
THEN
	RESPONSE #100
		SetGlobal("JO_Myself_Valid","LOCALS",1)
		Continue()
END

///////////////////////////////////////////////////////////////////////////////

// Security

///////////////////////////////////////////////////////////////////////////////
// Variables :
	// JO_JOIN (For Charname it allow to create an invisible creature that open a PID to manage travelers)
		// JO_JOIN_CUTSCENE (Deactive travelers for cutscene)
			// JO_Myself_Valid (Replace IsValidForPartyDialogue())
				// JO_JOIN_Move_Around (Centralised orders for all travelers at once)
///////////////////////////////////////////////////////////////////////////////

// Special Security/JOJOINNE.CRE
IF
	Global("JO_JOIN","LOCALS",1)
THEN
	RESPONSE #100
//		SetGlobal("JO_NOJOIN","GLOBAL",0)
		SetGlobal("JO_JOIN_Move_Around","GLOBAL",0) // Reset JO_JOIN_Move_Around
		SetGlobal("JO_JOIN","LOCALS",0) // Reset JO_JOIN
		SetGlobal("JO_JOIN_CUTSCENE","GLOBAL",0) // Security reset the cutscene global
		CreateCreatureObject("JOJOINNE",Myself,0,0,0)
END

// Prevent edge case when traveler special item finish in Player1 inventory
IF
	HasItem("JOMINHP1",Player1)
THEN
	RESPONSE #100
		DisplayStringHead(Myself, ~^RVoilà qui n'est pas normal... JOMINHP1 est dans mon inventaire !^-~)
		EquipItemEx("JOMINHP1",1)
		DestroyItem("JOMINHP1")
END

