IF
	Global("JO_JOIN_CAMPAIGN_BG2","MYAREA",0)
THEN
	RESPONSE #100
		SetGlobal("JO_JOIN_CAMPAIGN_BANTER","GLOBAL",3)
		ActionOverride(Player1,ChangeAIScript("JO_JOINP",OVERRIDE))
		SetGlobal("JO_JOIN_CAMPAIGN","GLOBAL",3)
		SetGlobal("JO_JOIN_CAMPAIGN_EET","GLOBAL",%CAMPAIGN_BG2EE%)
		SetGlobal("JO_JOIN_CAMPAIGN_BG2","MYAREA",1)
END
