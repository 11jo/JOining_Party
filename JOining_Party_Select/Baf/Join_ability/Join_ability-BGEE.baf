IF
	Global("JO_JOIN_CAMPAIGN_BG1","MYAREA",0)
THEN
	RESPONSE #100
		SetGlobal("JO_JOIN_CAMPAIGN_BANTER","GLOBAL",1)
		ActionOverride(Player1,ChangeAIScript("JO_JOINP",OVERRIDE))
		SetGlobal("JO_JOIN_CAMPAIGN","GLOBAL",1)
		SetGlobal("JO_JOIN_CAMPAIGN_EET","GLOBAL",%CAMPAIGN_BGEE%)
		SetGlobal("JO_JOIN_CAMPAIGN_BG1","MYAREA",1)
END
