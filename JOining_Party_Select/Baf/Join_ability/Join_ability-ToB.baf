IF
	Global("JO_JOIN_CAMPAIGN_ToB","MYAREA",0)
THEN
	RESPONSE #100
		SetGlobal("JO_JOIN_CAMPAIGN_BANTER","GLOBAL",4)
		ActionOverride(Player1,ChangeAIScript("JO_JOINP",OVERRIDE))
		SetGlobal("JO_JOIN_CAMPAIGN","GLOBAL",4)
		SetGlobal("JO_JOIN_CAMPAIGN_EET","GLOBAL",%CAMPAIGN_ToB%)
		SetGlobal("JO_JOIN_CAMPAIGN_ToB","MYAREA",1)
END


