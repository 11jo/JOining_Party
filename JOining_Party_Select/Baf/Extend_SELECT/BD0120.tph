ACTION_IF FILE_EXISTS ~weidu_external/JOining_Party_Select/All_In/Edwin_All_In.baf~ BEGIN

<<<<<<<< .../JOining_bd0120.baf

IF
	InMyArea("Edwin")
	Global("JO_JOIN_bd0120_Edwin","MYAREA",0)
	OR(4)
		!Global("JO_TRAVELER_Edwin","GLOBAL",0)
		TriggerOverride("Edwin",Allegiance(Myself,FAMILIAR))
		TriggerOverride("Edwin",Allegiance(Myself,CONTROLLED))
		!TriggerOverride("Edwin",Global("JO_JOIN_IS_TRAVELER","LOCALS",0))
THEN
	RESPONSE #100
		SetInterrupt(FALSE)
		ActionOverride("Edwin",ChangeAIScript("BDEDWIN",OVERRIDE))
		ActionOverride("Edwin",EquipItemEx("JOMINHP1",1))
		SmallWait(1)
		ActionOverride("Edwin",DestroyItem("JOMINHP1"))
		ActionOverride("Edwin",ChangeAIScript("JO_JOINI",GENERAL))
		SmallWait(1)
		ActionOverride("Edwin",ChangeEnemyAlly("Edwin",FAMILIAR))
		ActionOverride("Edwin",AddFamiliar())
		SetGlobal("JO_TRAVELER_Edwin","GLOBAL",1)
		ActionOverride("Edwin",SetGlobalTimer("JO_JOIN_SWITCH_TIMER","LOCALS",ONE_DAY))
		ActionOverride("Edwin",SetGlobal("JO_JOIN_IS_TRAVELER","LOCALS",1))
		SmallWait(1)
		ActionOverride("Edwin",GiveItemCreate("JOMINHP1",Myself,0,0,0))
		SmallWait(1)
		ActionOverride("Edwin",EquipItemEx("JOMINHP1",0))
		ActionOverride("Edwin",SetGlobal("JO_JOIN_SET_JOINX","LOCALS",3))
		ActionOverride("Edwin",ChangeAIScript("JO_JOINX",RACE))
		SetGlobal("JO_JOIN_bd0120_Edwin","MYAREA",1)
		ActionOverride("Edwin",DisplayString(Myself,~Still a traveler, let's loading switch when possible !~))
		SetInterrupt(TRUE)
		Continue()
END

IF
	Global("JO_JOIN_bd0120_Edwin","MYAREA",0)
THEN
	RESPONSE #100
		SetGlobal("JO_JOIN_bd0120_Edwin","MYAREA",1)
		Continue()
END

