IF
	!Global("JO_JOIN_IS_TRAVELER","LOCALS",0)
	InPartyAllowDead(Myself)
THEN
	RESPONSE #100
		SetTokenGlobal("JO_JOIN_IS_TRAVELER","LOCALS","JO_TEST_VALUE")
		DisplayStringHead(Myself,~^R Test - JO_JOIN_IS_TRAVELER = <JO_TEST_VALUE>, expected: 0^-~)
		SetGlobal("JO_JOIN_IS_TRAVELER","LOCALS",0)
END

IF
	Global("JO_JOIN_IS_TRAVELER","LOCALS",0)
	!InPartyAllowDead(Myself)
THEN
	RESPONSE #100
		SetTokenGlobal("JO_JOIN_IS_TRAVELER","LOCALS","JO_TEST_VALUE")
		DisplayStringHead(Myself,~^R Test - JO_JOIN_IS_TRAVELER = <JO_TEST_VALUE>, expected: 1^-~)
		SetGlobal("JO_JOIN_IS_TRAVELER","LOCALS",1)
END



///// TEST With Continue()

IF
	InPartySlot(Myself,0)
THEN
	RESPONSE #100
		DisplayStringHead(Myself,~^R Test - i'm Player1, expected: False -- No change^-~)
		Continue()
END

// JO_JOIN_SLEEPING_DEAD

