		DisplayStringHead(Myself,~^R Test - JO_JOIN_TALK value = <JO_TEST_VALUE>, expected: 0^-~)
		SetGlobal("JO_JOIN_TALK","LOCALS",0)
		Continue()
END










// END

IF
	True()
THEN
	RESPONSE #100
		SetGlobal("JO_JOIN_SET_JOINM","LOCALS",0)
		DisplayStringHead(Myself,~End test.~)
		ChangeAIScript("",RACE)
END
