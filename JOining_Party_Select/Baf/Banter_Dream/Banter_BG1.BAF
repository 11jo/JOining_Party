
IF
	PartyRested()
	Global("JO_JOIN_DREAM_DONE","LOCALS",1)
THEN	
	RESPONSE #100
		ChangeAIScript("",RACE)
		SetGlobal("JO_JOIN_DREAM_DONE","LOCALS",0)
//		SetGlobal("JO_JOIN_DREAM_REST","GLOBAL",0)
END

//
//
//
//
//
//
//
//
//

IF
//
	!Global("JO_JOIN_AREA_TRANSITION","GLOBAL",1) 
//	Global("JO_JOIN_DREAM_REST","GLOBAL",1) // Not at the moment related to Player1D.BAF
	Global("JO_JOIN_DREAM_DONE","LOCALS",0)
//
	OR(2)
//		Global("JO_JOIN_DREAM_REST","GLOBAL",1)
		HotKey(S)
		CheckStatGT([PC],6,FATIGUE)
	OR(3)
//		Global("JO_JOIN_DREAM_REST","GLOBAL",1)
		HotKey(S)
		TimeOfDay(NIGHT)
		TimeOfDay(DUSK)
//
	Global("JO_JOIN_LOADING","GLOBAL",0) // Not at loading
//
	!Global("JO_JOIN_SWITCHING","GLOBAL",1)
	!Global("JO_JOIN_LEAVE_PARTY","LOCALS",1)
//
	Global("JO_JOIN_IS_JOINING","LOCALS",0)
	Global("JO_JOIN_CUTSCENE","GLOBAL",0)
	Global("JO_JOIN","LOCALS",0)
	Global("JO_JOINI","LOCALS",0)
	Global("JO_NOJOIN","GLOBAL",0)
//
	!ActuallyInCombat()
	OR(3)
		Allegiance(Myself,FAMILIAR)
		Allegiance(Myself,CONTROLLED)
		!Global("JO_JOIN_IS_TRAVELER","LOCALS",0)
//
	Global("JO_JOIN_NEVER_BANTER","LOCALS",0)
	!Global("JO_Myself_Valid","LOCALS",0)
	Switch("JO_JOIN_CAMPAIGN_BANTER","GLOBAL")
//	RandomNum(4,2)
THEN
	RESPONSE #100
//		SetGlobal("JO_JOIN_DREAM_REST","GLOBAL",0)
		DisplayString(Myself,~Try to dream talk.~)
		ChangeAIScript("%BG1_DREAM%",RACE)
		SetGlobal("JO_JOIN_DREAM_DONE","LOCALS",1)
		Continue()
END

