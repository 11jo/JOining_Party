	Global("JO_JOINI","LOCALS",0)
	Global("JO_JOIN_CLEAR","LOCALS",0)
	Global("JO_JOIN_FORCE_SWITCH","LOCALS",0)
	Global("JO_JOIN_Fill_Party","LOCALS",0)
	Global("JO_JOIN_SLEEPING_DEAD","LOCALS",0)
	!GlobalGT("JO_JOIN_READY_TO_SWITCH","LOCALS",1)
//
	ActionListEmpty()
	Global("JO_JOIN_SLEEPING_DEAD","LOCALS",0)
	OR(3)
		Allegiance(Myself,FAMILIAR)
		Allegiance(Myself,CONTROLLED)
		!Global("JO_JOIN_IS_TRAVELER","LOCALS",0)
	StateCheck(Myself,STATE_SILENCED)
	Delay(60)
THEN
	RESPONSE #50
		DisplayString(Myself,~<GABBER> wave at you.~)
		Continue()
	RESPONSE #50
		DisplayString(Myself,~<GABBER> open they lips but not sound comes out...~)
		Continue()
END

