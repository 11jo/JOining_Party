///////////////////////////////////////////////////////////////////////////////

// Switching Party

///////////////////////////////////////////////////////////////////////////////
// Variables :
	// JO_JOIN_SWITCH_TIMER (Timer make sure the NPC stay long enough in party)
		// JO_JOIN_SWITCHING (Allow to temporise and reset variables in some case) (Also used to prevent other unrelated blocks to run)
			// JO_JOIN_SWITCH_WITH_ME (If set to 1 then the party member is available for switching with a traveler)
				// JO_JOIN_READY_TO_SWITCH (After some time in party, a party member can echange place with a traveler)
					// JO_JOIN_Wannabe (Party member eligible and willing to be traveler)
// Note :
	// Make traveler party member for some time regulary.
		// Used for maximise triggering all interactions
///////////////////////////////////////////////////////////////////////////////

// Main Switching Party 1

IF // First check
	Global("JO_JOIN_SWITCHING","GLOBAL",0) // Switching party step 0
// Global checks
	Global("JO_JOIN_AREA_TRANSITION","GLOBAL",0) // Compatible map
	Global("JO_JOIN_LOADING","GLOBAL",0) // Loading switch inactive
	Global("JO_JOIN_CUTSCENE","GLOBAL",0) // No cuscene
	Global("JO_NOJOIN","GLOBAL",0) // No join stop
	Global("JO_JOIN_RETURN_SLOT","GLOBAL",0) // Not implemented
//
	OR(2)
		!Global("JO_JOIN_AREA","MYAREA",0) // Is Master Area
		!Global("JO_JOIN_BLOP","GLOBAL",0)
// Local checks
	!GlobalGT("JO_JOIN_LEAVE_PARTY","LOCALS",0) // Leave Party inactive
	OR(2)
		!Global("JO_JOIN_PS_NO_TIMER_DEV","GLOBAL",0)
		!GlobalTimerNotExpired("JO_JOIN_SWITCH_TIMER","LOCALS") // Timer between switch exprired
	!Global("JO_Myself_Valid","LOCALS",0)
	!Global("JO_JOIN_IS_TRAVELER","LOCALS",0)
	Global("JO_JOIN_IS_JOINING","LOCALS",0) // Not joining party already
	Global("JO_JOIN","LOCALS",0)
	Global("JO_JOINI","LOCALS",0)
	Global("JO_JOIN_NEVER_SWITCH","LOCALS",0) // Can switch
	Global("JO_JOIN_SLEEPING_DEAD","LOCALS",0) // Not dead
// No combat
	OR(2)
		!ActuallyInCombat()
		!Global("JO_JOIN_BLOP","GLOBAL",0) // Dev test for ActuallyInCombat()
	OR(2)
		!See([ENEMY])
		!Global("JO_JOIN_BLOP","GLOBAL",0) // Dev test for See([ENEMY])

// Party member can be eligible
	NumInPartyAliveGT(1)
	!GlobalGT("JO_JOIN_PS_SAFE_SLOT","GLOBAL",5)
	OR(2)
		GlobalLT("JO_JOIN_PS_SAFE_SLOT","GLOBAL",1)
		NumInPartyGT(1)
	OR(2)
		GlobalLT("JO_JOIN_PS_SAFE_SLOT","GLOBAL",2)
		NumInPartyGT(2)
	OR(2)
		GlobalLT("JO_JOIN_PS_SAFE_SLOT","GLOBAL",3)
		NumInPartyGT(3)
	OR(2)
		GlobalLT("JO_JOIN_PS_SAFE_SLOT","GLOBAL",4)
		NumInPartyGT(4)
	OR(2)
		GlobalLT("JO_JOIN_PS_SAFE_SLOT","GLOBAL",5)
		NumInPartyGT(5)
THEN
	RESPONSE #100
		IncrementGlobal("JO_JOIN_SWITCHING","GLOBAL",1) // Switching party step 1
		SetGlobal("JO_JOIN_READY_TO_SWITCH","LOCALS",2) // It is my switching party
END

// Main Switching Party 2 // Randomly select a member... Wannabe !

IF // PartySlot6
	Global("JO_JOIN_SWITCHING","GLOBAL",1) // Switching party step 1
	Global("JO_JOIN_READY_TO_SWITCH","LOCALS",2) // It is my switching party
	Global("JO_JOIN_LOADING","GLOBAL",0) // Don't use this block at loading
	GlobalLT("JO_JOIN_PS_SAFE_SLOT","GLOBAL",6)

	!InPartySlot(PartySlot6,0) // security: not target Player1
	!TriggerOverride(PartySlot6,Global("JO_Myself_Valid","LOCALS",0))
	!TriggerOverride(PartySlot6,Global("JO_JOIN_Wannabe","LOCALS",0))
	OR(2)
		!Global("JO_JOIN_PS_NO_TIMER_DEV","GLOBAL",0)
		!TriggerOverride(PartySlot6,GlobalTimerNotExpired("JO_JOIN_SWITCH_TIMER","LOCALS"))
THEN
	RESPONSE #100
		SetInterrupt(FALSE)
		DisplayString(Myself,~Switching Party !~)
		FaceObject(PartySlot6)
		IncrementGlobal("JO_JOIN_SWITCHING","GLOBAL",1) // Switching party step 2
		SetGlobal("JO_JOIN_SWITCH_WITH_ME","LOCALS",6) // PartySlot6
		DisplayStringHead(PartySlot6,~Hum ?~)
		ActionOverride(PartySlot6,SetGlobal("JO_JOIN_READY_TO_SWITCH","LOCALS",3)) // active All_in block
		ActionOverride(PartySlot6,SetGlobal("JO_JOIN","LOCALS",1))
		SetInterrupt(TRUE)
END

