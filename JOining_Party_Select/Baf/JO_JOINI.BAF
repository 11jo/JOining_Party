	Global("JO_JOIN_SWITCHING","GLOBAL",1) // Switching party step 1
	Global("JO_JOIN_READY_TO_SWITCH","LOCALS",2) // It is my switching party
	Global("JO_JOIN_LOADING","GLOBAL",0) // Don't use this block at loading
	GlobalLT("JO_JOIN_PS_SAFE_SLOT","GLOBAL",5)

	!InPartySlot(PartySlot5,0) // security: not target Player1
	!TriggerOverride(PartySlot5,Global("JO_Myself_Valid","LOCALS",0))
	!TriggerOverride(PartySlot5,Global("JO_JOIN_Wannabe","LOCALS",0))
	OR(2)
		!Global("JO_JOIN_PS_NO_TIMER_DEV","GLOBAL",0)
		!TriggerOverride(PartySlot5,GlobalTimerNotExpired("JO_JOIN_SWITCH_TIMER","LOCALS"))
THEN
