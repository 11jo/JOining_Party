		FaceObject(PartySlot5)
		IncrementGlobal("JO_JOIN_SWITCHING","GLOBAL",1) // Switching party step 2
		SetGlobal("JO_JOIN_SWITCH_WITH_ME","LOCALS",5) // PartySlot5
		DisplayStringHead(PartySlot5,~What ?~)
		ActionOverride(PartySlot5,SetGlobal("JO_JOIN_READY_TO_SWITCH","LOCALS",3)) // active All_in block
		ActionOverride(PartySlot5,SetGlobal("JO_JOIN","LOCALS",1))
		SetInterrupt(TRUE)
END

IF // PartySlot4
	Global("JO_JOIN_SWITCHING","GLOBAL",1) // Switching party step 1
	Global("JO_JOIN_READY_TO_SWITCH","LOCALS",2) // It is my switching party
	Global("JO_JOIN_LOADING","GLOBAL",0) // Don't use this block at loading
	GlobalLT("JO_JOIN_PS_SAFE_SLOT","GLOBAL",4)

	!InPartySlot(PartySlot4,0) // security: not target Player1
	!TriggerOverride(PartySlot4,Global("JO_Myself_Valid","LOCALS",0))
	!TriggerOverride(PartySlot4,Global("JO_JOIN_Wannabe","LOCALS",0))
	OR(2)
		!Global("JO_JOIN_PS_NO_TIMER_DEV","GLOBAL",0)
		!TriggerOverride(PartySlot4,GlobalTimerNotExpired("JO_JOIN_SWITCH_TIMER","LOCALS"))
THEN
	RESPONSE #100
		SetInterrupt(FALSE)
		DisplayString(Myself,~Switching Party !~)
		FaceObject(PartySlot4)
		IncrementGlobal("JO_JOIN_SWITCHING","GLOBAL",1) // Switching party step 2
		SetGlobal("JO_JOIN_SWITCH_WITH_ME","LOCALS",4) // PartySlot4
		DisplayStringHead(PartySlot4,~Don't disturb...~)
		ActionOverride(PartySlot4,SetGlobal("JO_JOIN_READY_TO_SWITCH","LOCALS",3)) // active All_in block
		ActionOverride(PartySlot4,SetGlobal("JO_JOIN","LOCALS",1))
		SetInterrupt(TRUE)
END

IF // PartySlot3
	Global("JO_JOIN_SWITCHING","GLOBAL",1) // Switching party step 1
	Global("JO_JOIN_READY_TO_SWITCH","LOCALS",2) // It is my switching party
	Global("JO_JOIN_LOADING","GLOBAL",0) // Don't use this block at loading
	GlobalLT("JO_JOIN_PS_SAFE_SLOT","GLOBAL",3)

	!InPartySlot(PartySlot3,0) // security: not target Player1
	!TriggerOverride(PartySlot3,Global("JO_Myself_Valid","LOCALS",0))
	!TriggerOverride(PartySlot3,Global("JO_JOIN_Wannabe","LOCALS",0))
	OR(2)
		!Global("JO_JOIN_PS_NO_TIMER_DEV","GLOBAL",0)
		!TriggerOverride(PartySlot3,GlobalTimerNotExpired("JO_JOIN_SWITCH_TIMER","LOCALS"))
THEN
	RESPONSE #100
		SetInterrupt(FALSE)
