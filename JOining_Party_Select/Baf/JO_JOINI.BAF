///////////////////////////////////////////////////////////////////////////////

// JO_JOIN_Move_Around related to JOJOINNE.d

///////////////////////////////////////////////////////////////////////////////
// Variables : :
	// JO_JOIN_Move_Around (Set by charname PID to give instrucions to all travelers at once)
		// JO_JOIN_Move_Done (Prevent instruction boucle until JO_JOIN_Move_Around reset)
///////////////////////////////////////////////////////////////////////////////

IF
	Global("JO_JOIN_Move_Done","LOCALS",1)
THEN
	RESPONSE #1
		SetGlobal("JO_JOIN_Move_Around","GLOBAL",0)
		Wait(1)
		SetGlobal("JO_JOIN_Move_Done","LOCALS",0)
END

// Related to JOJOINNE.D groupe changes

IF
//
	Global("JO_JOIN_LOADING","GLOBAL",0) // Don't use this block at loading
	Global("JO_JOIN_RETURN_SLOT","GLOBAL",0)
	!Global("JO_JOIN_Move_Around","GLOBAL",0)
	!GlobalGT("JO_JOIN_Move_Done","LOCALS",0)
	OR(3)
		Allegiance(Myself,FAMILIAR)
		Allegiance(Myself,CONTROLLED)
		!Global("JO_JOIN_IS_TRAVELER","LOCALS",0)
	Switch("JO_JOIN_Move_Around","GLOBAL")
THEN
	RESPONSE #1
		SetGlobal("JO_JOIN_Move_Done","LOCALS",1)
		SetGlobal("JO_JOIN_HIDE_CUTSCENE","LOCALS",1)
		DisplayString(Myself,~Done.~)
		Continue()
	RESPONSE #2
		SetGlobal("JO_JOIN_Move_Done","LOCALS",1)
		SetGlobal("JO_JOIN_HIDE_CUTSCENE","LOCALS",0)
		DisplayString(Myself,~Done.~)
		Continue()
	RESPONSE #3
		SetGlobal("JO_JOIN_Move_Done","LOCALS",1)
		SetGlobal("JO_JOIN_NEVER_JOIN","LOCALS",1)
		DisplayString(Myself,~Done.~)
		Continue()
	RESPONSE #4
		SetGlobal("JO_JOIN_Move_Done","LOCALS",1)
		SetGlobal("JO_JOIN_NEVER_JOIN","LOCALS",0)
		DisplayString(Myself,~Done.~)
		Continue()
	RESPONSE #5
		SetGlobal("JO_JOIN_Move_Done","LOCALS",1)
		SetGlobal("JO_Myself_LeaveParty","LOCALS",1)
		DisplayString(Myself,~Done.~)
		Continue()
	RESPONSE #6
		SetGlobal("JO_JOIN_Move_Done","LOCALS",1)
		DisplayStringHead(Myself,~Youhou !~)
		Continue()
	RESPONSE #7
		SetGlobal("JO_JOIN_Move_Done","LOCALS",1)
		SetGlobal("JO_JOIN_FORCE_SWITCH","LOCALS",1)
		SetGlobal("JO_JOIN_IS_JOINING","LOCALS",0)
		DisplayString(Myself,~Done.~)
		Continue()
	RESPONSE #8
		SetGlobal("JO_JOIN_Move_Done","LOCALS",1)
		SetGlobal("JO_JOIN_LINK_TYPE","LOCALS",0)
		SetGlobal("JO_JOIN_LINK_PLAYER_ID","LOCALS",0)
		SetGlobal("BDAI_DISABLE_ATTACK","LOCALS",0)
		SetGlobal("BDAI_ATTACK_MODE","LOCALS",0)
		SetGlobal("BDAI_DISABLE_ITEMS","LOCALS",0)
		SetGlobal("BDAI_DISABLE_OFFENSIVE","LOCALS",0)
		SetGlobal("BDAI_DISABLE_DEFENSIVE","LOCALS",0)
		SetGlobal("BDAI_DISABLE_SPECIAL","LOCALS",0)
		SetGlobal("BDAI_SKILL_MODE","LOCALS",0)
		DisplayString(Myself,~Done.~)
		Continue()
	RESPONSE #9
		SetGlobal("JO_JOIN_Move_Done","LOCALS",1)
		MoveToObject(Player1)
		DisplayString(Myself,~Done.~)
	RESPONSE #10
		SetGlobal("JO_JOIN_Move_Done","LOCALS",1)
		SetGlobal("JO_JOIN_NEVER_SWITCH","LOCALS",1)
		DisplayString(Myself,~Done.~)
		Continue()
	RESPONSE #11
		SetGlobal("JO_JOIN_Move_Done","LOCALS",1)
		SetGlobal("JO_JOIN_NEVER_SWITCH","LOCALS",0)
		DisplayString(Myself,~Done.~)
		Continue()
	RESPONSE #12
		SetGlobal("JO_JOIN","LOCALS",0)

		SetGlobal("JO_NOJOIN","GLOBAL",0)
		SetGlobal("JO_NOJOIN_LOCALS","LOCALS",0)
		SetGlobal("JO_JOIN_IS_JOINING","LOCALS",0)
		SetGlobal("JO_JOINI","LOCALS",0)
		SetGlobal("JO_JOIN_TALK","LOCALS",0)
		SetGlobal("JO_JOIN_CLEAR","LOCALS",0)

//		SetGlobal("JO_JOIN_LOAD_PARTY","LOCALS",0)
//		SetGlobal("JO_JOIN_PARTY_SWITCH","GLOBAL",0)
//		SetGlobal("JO_JOIN_TRAVELER_SWITCH","GLOBAL",0)
//		SetGlobal("JO_JOIN_MY_SWITCH","LOCALS",0)

		SetGlobal("JO_JOIN_PRIVACY","LOCALS",0)
		SetGlobal("JO_JOIN_INDEPANDANCE","LOCALS",0)

		SetGlobal("JO_Myself_LeaveParty","LOCALS",0)
		SetGlobal("JO_JOIN_LEAVE_PARTY","LOCALS",0)
		SetGlobal("JO_JOIN_LEAVE_WAIT","LOCALS",0)
		SetGlobal("JO_JOIN_LEAVING_PARTY","GLOBAL",0)

		SetGlobal("JO_JOIN_NEVER_BANTER","LOCALS",0)
		SetGlobal("JO_JOIN_NEVER_SWITCH","LOCALS",0)
		SetGlobal("JO_JOIN_NEVER_JOIN","LOCALS",0)

		SetGlobal("JO_JOIN_IS_Wannabe","LOCALS",0)
		SetGlobalTimer("JO_JOIN_JOIN_TIMER","LOCALS",ONE_TURN)
		SetGlobalTimer("JO_JOIN_SWITCH_TIMER","LOCALS",ONE_TURN)
		SetGlobal("JO_JOIN_SWITCHING","GLOBAL",0)
		SetGlobal("JO_JOIN_READY_TO_SWITCH","LOCALS",0)
		SetGlobal("JO_JOIN_SWITCH_WITH_ME","LOCALS",0)
		SetGlobal("JO_JOIN_QUICK_SWITCH","LOCALS",0)
		SetGlobal("JO_JOIN_Fill_Party","LOCALS",0)

		SetGlobalTimer("JO_JOIN_BANTER_TIMER","LOCALS",ONE_TURN)
		SetGlobal("JO_JOIN_BANTER_INTERACT","LOCALS",0)
		SetGlobal("JO_JOIN_DREAM_DONE","LOCALS",0)
		SetGlobal("JO_JOIN_DREAM_REST","LOCALS",0)

		SetGlobal("JO_JOIN_Move_Done","LOCALS",1) // If not the script will loop...

		SetGlobal("JO_JOIN_CUTSCENE","GLOBAL",0)
		SetGlobal("JO_JOIN_HIDE_CUTSCENE","LOCALS",0)
		SetGlobal("JO_JOIN_IS_HIDDEN","LOCALS",0)
		Activate(Myself)


		SetGlobal("JO_JOIN_FORCE_LOAD","GLOBAL",0)
		SetGlobal("JO_JOIN_LOADING","GLOBAL",0)
		SetGlobal("JO_JOIN_LOAD","LOCALS",0)
		SetGlobal("JO_JOIN_LOADING_PLAYER","LOCALS",0)
		SetGlobal("JO_JOIN_LOAD_PARTY_WAIT","GLOBAL",0)

		SetGlobal("JO_JOIN_IS_TRAVELER","LOCALS",1)
		SetGlobal("JO_Myself_Valid","LOCALS",1)
		SetGlobal("JO_Myself_InParty","LOCALS",1)
		SetGlobal("JO_Myself_AllowDead","LOCALS",1)
		SetGlobal("JO_JOIN_SLEEPING_DEAD","LOCALS",0)

		EquipItemEx("JOMINHP1",0)
		DisplayString(Myself,@103)
	RESPONSE #13
		SetGlobal("JO_JOIN_Move_Done","LOCALS",1)
		SetGlobal("JO_JOIN_NEVER_BANTER","LOCALS",1)
		DisplayString(Myself,~Done.~)
		Continue()
	RESPONSE #14
		SetGlobal("JO_JOIN_Move_Done","LOCALS",1)
		SetGlobal("JO_JOIN_NEVER_BANTER","LOCALS",0)
		DisplayString(Myself,~Done.~)
		Continue()
	RESPONSE #15
		SetGlobal("JO_JOIN_Move_Done","LOCALS",1)
		SetGlobal("JO_JOIN_Fill_Party","LOCALS",1)
		DisplayString(Myself,~Done.~)
		Continue()
	RESPONSE #16 // Unused (replaced in JO_JOINC)
		SetGlobal("JO_JOIN_Move_Done","LOCALS",1)
//		SetGlobal("JO_JOIN_COUNT_TRAVELER","LOCALS",0) // Deprecated by JO_JOINC.BAF
//		SetGlobal("JO_JOIN_COUNT_TRAVELER","GLOBAL",1) // Deprecated by JO_JOINC.BAF
		DisplayString(Myself,~Done.~)
		Continue()
	RESPONSE #17
		SetGlobal("JO_JOIN_Move_Done","LOCALS",1)
		SetGlobal("JO_JOIN_LINK_TYPE","LOCALS",2)
		DisplayString(Myself,~Done.~)
		Continue()
	RESPONSE #18
		SetGlobal("JO_JOIN_MOVE_INDEPENDANT","LOCALS",0)
		SetGlobal("JO_JOIN_NEED_INDEPANDANT","LOCALS",0)
		SetGlobal("JO_JOIN_Move_Done","LOCALS",1)
		Continue()
	RESPONSE #19
		SetGlobal("JO_JOIN_MOVE_INDEPENDANT","LOCALS",0)
		SetGlobal("JO_JOIN_NEED_INDEPANDANT","LOCALS",3)
		SetGlobal("JO_JOIN_Move_Done","LOCALS",1)
		DisplayString(Myself,~Done.~)
	RESPONSE #20
		SetGlobal("JO_JOIN_MOVE_INDEPENDANT","LOCALS",0)
		SetGlobal("JO_JOIN_NEED_INDEPANDANT","LOCALS",5)
		SetGlobal("JO_JOIN_Move_Done","LOCALS",1)
		DisplayString(Myself,~Done.~)
	RESPONSE #21
		SetGlobal("JO_JOIN_MOVE_INDEPENDANT","LOCALS",0)
		SetGlobal("JO_JOIN_NEED_INDEPANDANT","LOCALS",8)
		SetGlobal("JO_JOIN_Move_Done","LOCALS",1)
		DisplayString(Myself,~Done.~)
	RESPONSE #22
		SetGlobal("JO_JOIN_MOVE_INDEPENDANT","LOCALS",0)
		SetGlobal("JO_JOIN_NEED_INDEPANDANT","LOCALS",10)
		SetGlobal("JO_JOIN_Move_Done","LOCALS",1)
		DisplayString(Myself,~Done.~)
	RESPONSE #23
		SetGlobal("JO_JOIN_Move_Done","LOCALS",1)
		SetGlobal("JO_JOIN_CONTROLLED","LOCALS",0)
		ChangeEnemyAlly(Myself,FAMILIAR)
//		AddFamiliar()
		DisplayString(Myself,~Done. I am linked to you !~)
/*	RESPONSE #24
		SetGlobal("JO_JOIN_Move_Done","LOCALS",1)
		SetGlobal("JO_JOIN_CONTROLLED","LOCALS",1)
		ChangeEnemyAlly(Myself,CONTROLLED)*/
		DisplayString(Myself,~Done. I am more independant !~)
	RESPONSE #25
		SetGlobal("JO_JOIN_Move_Done","LOCALS",1)
		SetGlobal("JO_JOIN_LINK_TYPE","LOCALS",-1)
		DisplayString(Myself,~Done. I stay put.~)
		Continue()
	RESPONSE #26
		SetGlobal("JO_JOIN_Move_Done","LOCALS",1)
		SetGlobal("JO_JOIN_NEVER_FILL","LOCALS",0)
		Continue()
	RESPONSE #27
		SetGlobal("JO_JOIN_Move_Done","LOCALS",1)
		SetGlobal("JO_JOIN_NEVER_FILL","LOCALS",1)
		Continue()
//	RESPONSE #28 // Party member only
		//SetGlobal("JO_JOIN_Move_Done","LOCALS",1)
		//Continue()
//	RESPONSE #29 // Party member only
		//SetGlobal("JO_JOIN_Move_Done","LOCALS",1)
		//Continue()
/*	RESPONSE #30
		SetGlobal("JO_JOIN_Move_Done","LOCALS",1)
		Continue()*/
END

///////////////////////////////////////////////////////////////////////////////

// Security

///////////////////////////////////////////////////////////////////////////////

// Related to Reintegrate NPC into party periodically

IF // security check
// 
	Global("JO_JOIN_LOADING","GLOBAL",0) // Don't use this block at loading TODO : Yes or no, maybe irrelevant with the new Loading Switch...
	OnCreation()
	!Global("JO_JOIN_IS_JOINING","LOCALS",0)
	OR(3)
		Allegiance(Myself,FAMILIAR)
		Allegiance(Myself,CONTROLLED)
		!Global("JO_JOIN_IS_TRAVELER","LOCALS",0)
THEN
	RESPONSE #100
		SetGlobal("JO_JOIN_JOIN_TIMER","LOCALS",0)
		SetGlobal("JO_NOJOIN","GLOBAL",0)
		SetGlobal("JO_NOJOIN_LOCALS","LOCALS",0)
		SetGlobal("JO_JOIN_IS_JOINING","LOCALS",0)
		Continue()
END

///////////////////////////////////////////////////////////////////////////////

// Quick Switch

///////////////////////////////////////////////////////////////////////////////
// Variables : :
	// JO_JOIN_JOIN_TIMER (Set when a party member become a traveler or when a traveler do a quick switch)
		// JO_JOIN_FORCE_SWITCH (Set by PID)
			// JO_JOIN_IS_JOINING (Set when the traveler reintegrate the party for a Quick Switch)
				// JO_JOINI (Set when a traveler is in party for a Quick Switch)
// Note :
	// Regular switch
		// Launched with dialog
			// Also launched by JO_JOIN_JOIN_TIMER
				// Also used by Loading Party
///////////////////////////////////////////////////////////////////////////////

// Main Quick Switch 1

IF
//
	Global("JO_JOIN_LOADING","GLOBAL",0) // Don't use this block at loading
	Global("JO_JOIN_RETURN_SLOT","GLOBAL",0)
	Global("JO_JOIN_NEVER_JOIN","LOCALS",0)
	!GlobalTimerNotExpired("JO_JOIN_JOIN_TIMER","LOCALS")
	!Global("JO_JOIN_JOIN_TIMER","LOCALS",1)
THEN
	RESPONSE #100
		SetGlobal("JO_JOIN_JOIN_TIMER","LOCALS",1) // Enable next block
		SetGlobal("JO_JOIN_QUICK_SWITCH","LOCALS",0) // Temporise Quick Switch
		DisplayString(Myself,~Ready for a Quick Switch.~)
END

// Secondary Quick Switch 1

// Block wait 1 for Quick Switch

IF
//
	Global("JO_JOIN_LOADING","GLOBAL",0) // Don't use this block at loading
	Global("JO_JOIN_RETURN_SLOT","GLOBAL",0)
	Global("JO_JOIN_SWITCHING","GLOBAL",0)
	Global("JO_NOJOIN","GLOBAL",0)
	Global("JO_JOIN_LEAVING_PARTY","GLOBAL",0)
	Global("JO_JOIN_Fill_Party","LOCALS",0)
// 
	Global("JO_JOIN_NEVER_JOIN","LOCALS",0)
	Global("JO_JOIN_JOIN_TIMER","LOCALS",1) 
	!Global("JO_JOIN_QUICK_SWITCH","LOCALS",1)
	NumInPartyLT(6)
THEN
	RESPONSE #100
		SetGlobal("JO_JOIN_QUICK_SWITCH","LOCALS",1) // Enable next block
END

// Secondary Quick Switch 1

IF // Block wait 2 for Quick Switch // Return to Main Quick Switch 1 if another traveler is already active
//
	Global("JO_JOIN_AREA_TRANSITION","GLOBAL",1) 
//
	Global("JO_JOIN_LOADING","GLOBAL",0) // Don't use this block at loading
	Global("JO_JOIN_RETURN_SLOT","GLOBAL",0)
	OR(4)
		!Global("JO_JOIN_SWITCHING","GLOBAL",0)
		!Global("JO_NOJOIN","GLOBAL",0)
		!Global("JO_JOIN_LEAVING_PARTY","GLOBAL",0)
		!Global("JO_JOIN_Fill_Party","LOCALS",0)
// 
	Global("JO_JOIN_NEVER_JOIN","LOCALS",0)
	Global("JO_JOIN_JOIN_TIMER","LOCALS",1) 
	Global("JO_JOIN_QUICK_SWITCH","LOCALS",1)
	NumInPartyLT(6)
THEN
	RESPONSE #100
		SetGlobal("JO_JOIN_QUICK_SWITCH","LOCALS",0) // Enable next block
		DisplayString(Myself,~I have to wait before a Quick Switch.~)
		Continue()
END

// Main Quick Switch 2

IF
	OR(2)
		Global("JO_JOIN_FORCE_SWITCH","LOCALS",1) // Set by JO_JOIN_Move_Around
		Delay(20)
//
	!Global("JO_JOIN_AREA_TRANSITION","GLOBAL",1) 
//
	Global("JO_JOIN_LOADING","GLOBAL",0) // Don't use this block at loading
	Global("JO_JOIN_RETURN_SLOT","GLOBAL",0)
	Global("JO_JOIN_SWITCHING","GLOBAL",0)
	Global("JO_JOIN_LEAVING_PARTY","GLOBAL",0)
	Global("JO_JOIN_Fill_Party","LOCALS",0)
//
	OR(2)
		Global("JO_JOIN_AREA","MYAREA",1) // Master Area
		Global("JO_JOIN_BLOP","GLOBAL",1) //Testing variable
//
	OR(2)
		Global("JO_JOIN_FORCE_SWITCH","LOCALS",1) // Set by JO_JOIN_Move_Around
//		Global("JO_JOIN_Fill_Party","LOCALS",1) // Set by JO_JOIN_Move_Around  // TODO : Verify why it was here, should be standalone
		Global("JO_JOIN_JOIN_TIMER","LOCALS",1)
//
//	ActionListEmpty()
	OR(2)
		!ActuallyInCombat()
		Global("JO_JOIN_BLOP","GLOBAL",1) // Dev test for ActuallyInCombat()
	OR(2)
		!See([ENEMY])
		Global("JO_JOIN_BLOP","GLOBAL",1) // Dev test for See([ENEMY])
//
	OR(3)
		Allegiance(Myself,FAMILIAR)
		Allegiance(Myself,CONTROLLED)
		!Global("JO_JOIN_IS_TRAVELER","LOCALS",0)
//
	Global("JO_JOIN_CUTSCENE","GLOBAL",0)
	Global("JO_NOJOIN","GLOBAL",0)
	OR(2)
		Global("JO_JOIN_FORCE_SWITCH","LOCALS",1) // Set by JO_JOIN_Move_Around
		Global("JO_JOIN_NEVER_JOIN","LOCALS",0)
	Global("JO_JOIN_IS_JOINING","LOCALS",0)
	!Global("JO_JOIN_LINK_TYPE","LOCALS",-1) // != static mode
// 
	OR(2)
		Global("JO_JOIN_FORCE_SWITCH","LOCALS",1) // Set by JO_JOIN_Move_Around
		Global("JO_JOIN_QUICK_SWITCH","LOCALS",1)
	NumInPartyLT(6)
	Switch("JO_JOIN_LINK_PLAYER_ID","LOCALS")
THEN
	RESPONSE #0
		SetInterrupt(FALSE)
		DisplayString(Myself,~Don't worry, I won't disturb the group long.~)
		SetGlobal("JO_NOJOIN_LOCALS","LOCALS",1)
		SetGlobal("JO_NOJOIN","GLOBAL",1)
		SetGlobal("JO_JOIN_IS_JOINING","LOCALS",1)
		SetGlobal("JO_JOIN_QUICK_SWITCH","LOCALS",0)
		SmallWait(1)
		MoveToObject(Player1Fill)
		SetInterrupt(TRUE)
	RESPONSE #1
		SetInterrupt(FALSE)
		DisplayString(Myself,~Don't worry, I won't disturb the group long.~)
		SetGlobal("JO_NOJOIN_LOCALS","LOCALS",1)
		SetGlobal("JO_NOJOIN","GLOBAL",1)
		SetGlobal("JO_JOIN_IS_JOINING","LOCALS",1)
		SetGlobal("JO_JOIN_QUICK_SWITCH","LOCALS",0)
		SmallWait(1)
		MoveToObject(Player1)
		SetInterrupt(TRUE)
	RESPONSE #2
		SetInterrupt(FALSE)
		DisplayString(Myself,~Don't worry, I won't disturb the group long.~)
		SetGlobal("JO_NOJOIN_LOCALS","LOCALS",1)
		SetGlobal("JO_NOJOIN","GLOBAL",1)
		SetGlobal("JO_JOIN_IS_JOINING","LOCALS",1)
		SetGlobal("JO_JOIN_QUICK_SWITCH","LOCALS",0)
		SmallWait(1)
		MoveToObject(Player2)
		SetInterrupt(TRUE)
	RESPONSE #3
		SetInterrupt(FALSE)
		DisplayString(Myself,~Don't worry, I won't disturb the group long.~)
		SetGlobal("JO_NOJOIN_LOCALS","LOCALS",1)
		SetGlobal("JO_NOJOIN","GLOBAL",1)
		SetGlobal("JO_JOIN_IS_JOINING","LOCALS",1)
		SetGlobal("JO_JOIN_QUICK_SWITCH","LOCALS",0)
		SmallWait(1)
		MoveToObject(Player3)
		SetInterrupt(TRUE)
	RESPONSE #4
		SetInterrupt(FALSE)
		DisplayString(Myself,~Don't worry, I won't disturb the group long.~)
		SetGlobal("JO_NOJOIN_LOCALS","LOCALS",1)
		SetGlobal("JO_NOJOIN","GLOBAL",1)
		SetGlobal("JO_JOIN_IS_JOINING","LOCALS",1)
		SetGlobal("JO_JOIN_QUICK_SWITCH","LOCALS",0)
		SmallWait(1)
		MoveToObject(Player4)
		SetInterrupt(TRUE)
	RESPONSE #5
		SetInterrupt(FALSE)
		DisplayString(Myself,~Don't worry, I won't disturb the group long.~)
		SetGlobal("JO_NOJOIN_LOCALS","LOCALS",1)
		SetGlobal("JO_NOJOIN","GLOBAL",1)
		SetGlobal("JO_JOIN_IS_JOINING","LOCALS",1)
		SetGlobal("JO_JOIN_QUICK_SWITCH","LOCALS",0)
		SmallWait(1)
		MoveToObject(Player5)
		SetInterrupt(TRUE)
	RESPONSE #6
		SetInterrupt(FALSE)
		DisplayString(Myself,~Don't worry, I won't disturb the group long.~)
		SetGlobal("JO_NOJOIN_LOCALS","LOCALS",1)
		SetGlobal("JO_NOJOIN","GLOBAL",1)
		SetGlobal("JO_JOIN_IS_JOINING","LOCALS",1)
		SetGlobal("JO_JOIN_QUICK_SWITCH","LOCALS",0)
		SmallWait(1)
		MoveToObject(Player6)
		SetInterrupt(TRUE)
END

// Reintegrate NPC into party periodically
	// Used by Regular switch 
				// Also used by Loading Party

// Main Quick Switch 3

IF
// 
	OR(2)
		Global("JO_JOIN_AREA","MYAREA",1)
		Global("JO_JOIN_BLOP","GLOBAL",1)
//
//		ActionListEmpty()
	OR(2)
		!ActuallyInCombat()
		Global("JO_JOIN_BLOP","GLOBAL",1) // Dev test for ActuallyInCombat()
	OR(2)
		!See([ENEMY])
		Global("JO_JOIN_BLOP","GLOBAL",1) // Dev test for See([ENEMY])
	OR(3)
		Allegiance(Myself,FAMILIAR)
		Allegiance(Myself,CONTROLLED)
		!Global("JO_JOIN_IS_TRAVELER","LOCALS",0)
//
	!Global("JO_JOIN_IS_JOINING","LOCALS",0)
	Global("JO_JOIN_CUTSCENE","GLOBAL",0)
//
	NumInPartyLT(6)
THEN
	RESPONSE #100
		SetInterrupt(FALSE)
		SetGlobalTimer("JO_JOIN_JOIN_TIMER","LOCALS",TWO_DAYS)
		SetGlobal("JO_JOIN_IS_JOINING","LOCALS",0)
		SetGlobal("JO_JOINI","LOCALS",1)
		SetGlobal("JO_JOIN_CLEAR","LOCALS",1) // ScriptAction All_in_Baf
		EquipItemEx("JOMINHP1",1)
		// SmallWait(1)
		DestroyItem("JOMINHP1")
		// SmallWait(1)
		DisplayString(Myself,~Hey.~)
		SetInterrupt(TRUE)
		JoinParty() // Go to All_In_Baf Switch between familiar and party
END

///////////////////////////////////////////////////////////////////////////////

// Security

///////////////////////////////////////////////////////////////////////////////

// Broken links

IF // unexpected values
	OR(2)
		GlobalLT("JO_JOIN_LINK_PLAYER_ID","LOCALS",0)
		GlobalGT("JO_JOIN_LINK_PLAYER_ID","LOCALS",6)
	Global("JO_JOIN_CUTSCENE","GLOBAL",0)
THEN
	RESPONSE #100
		SetGlobal("JO_JOIN_LINK_PLAYER_ID","LOCALS",0)
END

IF
	Global("JO_JOIN_LINK_PLAYER_ID","LOCALS",1)
	Global("JO_JOIN_CUTSCENE","GLOBAL",0)
	OR(2)
		!InParty(Player1)
		!Exists(Player1) // TODO: useful ?
THEN
	RESPONSE #100
		SetGlobal("JO_JOIN_LINK_PLAYER_ID","LOCALS",0)
END

IF
//
	Global("JO_JOIN_LOADING","GLOBAL",0) // Don't use this block at loading
	Global("JO_JOIN_RETURN_SLOT","GLOBAL",0)
//
	Global("JO_JOIN_LINK_PLAYER_ID","LOCALS",2)
	Global("JO_JOIN_CUTSCENE","GLOBAL",0)
	OR(2)
		!InParty(Player2)
		!Exists(Player2)
THEN
	RESPONSE #100
		SetGlobal("JO_JOIN_LINK_PLAYER_ID","LOCALS",0)
END

IF
//
	Global("JO_JOIN_LOADING","GLOBAL",0) // Don't use this block at loading
	Global("JO_JOIN_RETURN_SLOT","GLOBAL",0)
//
	Global("JO_JOIN_LINK_PLAYER_ID","LOCALS",3)
	Global("JO_JOIN_CUTSCENE","GLOBAL",0)
	OR(2)
		!InParty(Player3)
		!Exists(Player3)
THEN
	RESPONSE #100
		SetGlobal("JO_JOIN_LINK_PLAYER_ID","LOCALS",0)
END

IF
//
	Global("JO_JOIN_LOADING","GLOBAL",0) // Don't use this block at loading
	Global("JO_JOIN_RETURN_SLOT","GLOBAL",0)
//
	Global("JO_JOIN_LINK_PLAYER_ID","LOCALS",4)
	Global("JO_JOIN_CUTSCENE","GLOBAL",0)
	OR(2)
		!InParty(Player4)
		!Exists(Player4)
THEN
	RESPONSE #100
		SetGlobal("JO_JOIN_LINK_PLAYER_ID","LOCALS",0)
END

IF
//
	Global("JO_JOIN_LOADING","GLOBAL",0) // Don't use this block at loading
	Global("JO_JOIN_RETURN_SLOT","GLOBAL",0)
//
	Global("JO_JOIN_LINK_PLAYER_ID","LOCALS",5)
	Global("JO_JOIN_CUTSCENE","GLOBAL",0)
	OR(2)
		!InParty(Player5)
		!Exists(Player5)
THEN
	RESPONSE #100
		SetGlobal("JO_JOIN_LINK_PLAYER_ID","LOCALS",0)
END

IF
//
	Global("JO_JOIN_LOADING","GLOBAL",0) // Don't use this block at loading
	Global("JO_JOIN_RETURN_SLOT","GLOBAL",0)
//
	Global("JO_JOIN_LINK_PLAYER_ID","LOCALS",6)
	Global("JO_JOIN_CUTSCENE","GLOBAL",0)
	OR(2)
		!InParty(Player6)
		!Exists(Player6)
THEN
	RESPONSE #100
		SetGlobal("JO_JOIN_LINK_PLAYER_ID","LOCALS",0)
END

///////////////////////////////////////////////////////////////////////////////

// Move to linked player

///////////////////////////////////////////////////////////////////////////////
// Note :
	// Familiar without link : the linked player is the first player in the party (which may not be Player1)
///////////////////////////////////////////////////////////////////////////////


// Large range or different area
IF
//
	Global("JO_JOIN_LOADING","GLOBAL",0) // Don't use this block at loading
	Global("JO_JOIN_RETURN_SLOT","GLOBAL",0)
	Global("JO_JOIN_SWITCHING","GLOBAL",0) // Don't use this block when Switching Party
	Global("JO_JOIN_LEAVING_PARTY","GLOBAL",0) // Don't use this block when Leave Party
	Global("JO_NOJOIN","GLOBAL",0)
//
	Global("JO_JOIN_LINK_PLAYER_ID","LOCALS",0) // no linked
	!Global("JO_JOIN_LINK_TYPE","LOCALS",-1) // != static mode
	Global("JO_JOIN_CUTSCENE","GLOBAL",0) // no cutscene
	ActionListEmpty()
	!ActuallyInCombat() // TODO: Added // Prevent linked traveler to avoid a fight to follow a party member
	!See([ENEMY])
	OR(3)
		Allegiance(Myself,FAMILIAR)
		Allegiance(Myself,CONTROLLED)
		!Global("JO_JOIN_IS_TRAVELER","LOCALS",0)
	!Range(Player1Fill,100)
//
THEN
	RESPONSE #100
		MoveGlobalObject(Myself,Player1Fill) // JumpToObject(PlayerX) // MoveGlobalObject(Myself,PlayerX)
END

// Short range
IF
//
	Global("JO_JOIN_LOADING","GLOBAL",0) // Don't use this block at loading
	Global("JO_JOIN_RETURN_SLOT","GLOBAL",0)
	Global("JO_JOIN_SWITCHING","GLOBAL",0) // Don't use this block when Switching Party
	Global("JO_JOIN_LEAVING_PARTY","GLOBAL",0) // Don't use this block when Leave Party
	Global("JO_NOJOIN","GLOBAL",0)
//
	Global("JO_JOIN_LINK_PLAYER_ID","LOCALS",0)
	GlobalGT("JO_JOIN_LINK_TYPE","LOCALS",0) // follow with authorised move
	Global("JO_JOIN_CUTSCENE","GLOBAL",0) // no cutscene
	ActionListEmpty()
	!ActuallyInCombat() // TODO: Added
	OR(3)
		Allegiance(Myself,FAMILIAR)
		Allegiance(Myself,CONTROLLED)
		!Global("JO_JOIN_IS_TRAVELER","LOCALS",0)
	!PersonalSpaceDistance(Player1Fill,5) // PersonalSpaceDistance is more reliable than Range at such a low range
	OR(2)
		Global("JO_JOIN_LINK_TYPE","LOCALS",2) // follow close
		!Range(Player1Fill,50)
THEN
	RESPONSE #100
		MoveToObject(Player1Fill)
END

///////////////////////////////////////////////////////////////////////////////

// Not to Short range
IF
//
	Global("JO_JOIN_LOADING","GLOBAL",0) // Don't use this block at loading
	Global("JO_JOIN_RETURN_SLOT","GLOBAL",0)
	Global("JO_JOIN_SWITCHING","GLOBAL",0) // Don't use this block when Switching Party
	Global("JO_JOIN_LEAVING_PARTY","GLOBAL",0) // Don't use this block when Leave Party
	Global("JO_NOJOIN","GLOBAL",0)
//
	Delay(5)
	Global("JO_JOIN_LINK_PLAYER_ID","LOCALS",0)
	GlobalGT("JO_JOIN_LINK_TYPE","LOCALS",0) // follow with authorised move
	Global("JO_JOIN_CUTSCENE","GLOBAL",0) // no cutscene
	ActionListEmpty()
	!ActuallyInCombat() // TODO: Added
	!See([ENEMY])
	OR(3)
		Allegiance(Myself,FAMILIAR)
		Allegiance(Myself,CONTROLLED)
		!Global("JO_JOIN_IS_TRAVELER","LOCALS",0)
	PersonalSpaceDistance(Player1,5) // PersonalSpaceDistance is more reliable than Range at such a low range
	OR(2)
		Global("JO_JOIN_LINK_TYPE","LOCALS",2) // follow close
		Range(Player1Fill,5)
THEN
	RESPONSE #10
		MoveToOffset([0.5])
	RESPONSE #10
		MoveToOffset([5.0])
	RESPONSE #10
		MoveToOffset([0.-5])
	RESPONSE #10
		MoveToOffset([-5.0])
	RESPONSE #60
		NoAction()
END

