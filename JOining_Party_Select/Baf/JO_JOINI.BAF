	OR(3)
		Allegiance(Myself,FAMILIAR)
		Allegiance(Myself,CONTROLLED)
		!Global("JO_JOIN_IS_TRAVELER","LOCALS",0)
	CheckSpellState(Myself,DEAFENED)
	Delay(60)
THEN
	RESPONSE #40
		DisplayString(Myself,~Speak up, speak up !~) // Parlez plus fort, plus fort ! (@11086)
		Continue()
