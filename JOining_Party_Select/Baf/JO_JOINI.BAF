///////////////////////////////////////////////////////////////////////////////////

// JO_JOIN_CUTSCENE

///////////////////////////////////////////////////////////////////////////////////
// Variables :
	// JO_JOIN_HIDE_CUTSCENE (Set in PID, enable or disable travelers in cutscene)
		// JO_JOIN_IS_HIDDEN (Set in PID, enable or disable travelers in cutscene)
			// JO_JOIN_CUTSCENE (General global set ny all game cutscenes)
// Note :
	// Active or deactive travelers in cutscene.
///////////////////////////////////////////////////////////////////////////////////

///////////////////////////////////////////////////////////////////////////////////

IF // Security, nothing should prevent a loading switch
//
	OR(2)
		AreaCheck("JO2608")
		Global("JO_JOIN_LOADING","GLOBAL",3)
	!IsActive(Myself)
THEN
	RESPONSE #100
		Activate(Myself)
END

///////////////////////////////////////////////////////////////////////////////////


IF
//
	!AreaCheck("JO2608")
	Global("JO_JOIN_LOADING","GLOBAL",0)
	OR(2)
		!Global("JO_JOIN_HIDE_CUTSCENE","LOCALS",0)
		Global("JO_JOIN_FORCE_HIDE","GLOBAL",1)
	OR(3)
		Allegiance(Myself,FAMILIAR)
		Allegiance(Myself,CONTROLLED)
		!Global("JO_JOIN_IS_TRAVELER","LOCALS",0)
	OR(2)
		Global("JO_JOIN_CUTSCENE","GLOBAL",1)
		Global("JO_JOIN_FORCE_HIDE","GLOBAL",1)
	IsActive(Myself)
THEN
	RESPONSE #100
		SetGlobal("JO_JOIN_IS_HIDDEN","LOCALS",1)
		Deactivate(Myself)
END

IF
//
	!Global("JO_JOIN_FORCE_HIDE","GLOBAL",1)
//
	!Global("JO_JOIN_IS_HIDDEN","LOCALS",0)
	OR(3)
		Allegiance(Myself,FAMILIAR)
		Allegiance(Myself,CONTROLLED)
		!Global("JO_JOIN_IS_TRAVELER","LOCALS",0)
	Global("JO_JOIN_CUTSCENE","GLOBAL",0)
	!IsActive(Myself)
THEN
	RESPONSE #100
		Activate(Myself)
		SetGlobal("JO_JOIN_IS_HIDDEN","LOCALS",0)
		Continue()
END

///////////////////////////////////////////////////////////////////////////////////

// Privacy / Indepandance

///////////////////////////////////////////////////////////////////////////////////
// Variables : :
	// JO_JOIN_PRIVACY (Automatically deactive travelers if Charname is in another area of the party)
		// JO_JOIN_INDEPANDANCE (PID option : Deactive travelers if Charname is separate from the party but in the same area)
// Note :
	// Privacy automatically Active or deactive travelers when Player1 is alone in the area. (Related to mod like Romantic Encounters)
			// Indepandance ask to a traveler to deactive themselves when Player1 walks away from the party.
///////////////////////////////////////////////////////////////////////////////

IF
//
	!AreaCheck("JO2608")
	Global("JO_JOIN_LOADING","GLOBAL",0)
	Global("JO_JOIN_NOPRIVACY","GLOBAL",0)
	Global("JO_JOIN_PRIVACY","LOCALS",0)
	NumInPartyGT(1)
	!InMyArea(Player2)
	!InMyArea(Player3)
	!InMyArea(Player4)
	!InMyArea(Player5)
	!InMyArea(Player6)
THEN
	RESPONSE #100
		SetGlobal("JO_JOIN_PRIVACY","LOCALS",1)
		Deactivate(Myself)
END

IF
//
	!Global("JO_JOIN_CUTSCENE","GLOBAL",1) // Don't reactivate if cutscene is in motion
//
	OR(5)
		InMyArea(Player2)
		InMyArea(Player3)
		InMyArea(Player4)
		InMyArea(Player5)
		InMyArea(Player6)
	Global("JO_JOIN_PRIVACY","LOCALS",1)
THEN
	RESPONSE #100
		SetGlobal("JO_JOIN_PRIVACY","LOCALS",0)
		Activate(Myself)
END

IF
//
	Global("JO_JOIN_LOADING","GLOBAL",0) // Don't use this block at loading
	Global("JO_JOIN_RETURN_SLOT","GLOBAL",0)
	Global("JO_JOIN_SWITCHING","GLOBAL",0) // Don't use this block when Switching Party
	Global("JO_JOIN_LEAVING_PARTY","GLOBAL",0) // Don't use this block when Leave Party
	Global("JO_NOJOIN","GLOBAL",0)
// 
	OR(3)
		Allegiance(Myself,FAMILIAR)
		Allegiance(Myself,CONTROLLED)
		!Global("JO_JOIN_IS_TRAVELER","LOCALS",0)
//
	Global("JO_JOIN_IS_JOINING","LOCALS",0)
	Global("JO_JOIN_CUTSCENE","GLOBAL",0)
	Global("JO_JOIN","LOCALS",0)
	Global("JO_JOINI","LOCALS",0)
//
	Global("JO_JOIN_MOVE_INDEPENDANT","LOCALS",0)
	Switch("JO_JOIN_NEED_INDEPANDANT","LOCALS")
THEN
	RESPONSE #0
		SetGlobal("JO_JOIN_MOVE_INDEPENDANT","LOCALS",1)
		SetGlobal("JO_JOIN_INDEPANDANCE","LOCALS",0)
		DisplayString(Myself,~I am reassured.~)
		Continue()
	RESPONSE #3
		SetGlobal("JO_JOIN_MOVE_INDEPENDANT","LOCALS",1)
		SetGlobal("JO_JOIN_INDEPANDANCE","LOCALS",3)
		DisplayString(Myself,~I watch you from here.~)
		Continue()
	RESPONSE #5
		SetGlobal("JO_JOIN_MOVE_INDEPENDANT","LOCALS",1)
		SetGlobal("JO_JOIN_INDEPANDANCE","LOCALS",5)
		DisplayString(Myself,~Don't step away too much.~)
		Continue()
	RESPONSE #8
		SetGlobal("JO_JOIN_MOVE_INDEPENDANT","LOCALS",1)
		SetGlobal("JO_JOIN_INDEPANDANCE","LOCALS",8)
		DisplayString(Myself,~Don't go too far.~)
		Continue()
	RESPONSE #10
		SetGlobal("JO_JOIN_MOVE_INDEPENDANT","LOCALS",1)
		SetGlobal("JO_JOIN_INDEPANDANCE","LOCALS",10)
		DisplayString(Myself,~Be careful out there.~)
		Continue()

END


IF // Range 100
//
	!AreaCheck("JO2608")
	Global("JO_JOIN_LOADING","GLOBAL",0)
	NumInPartyGT(1)
	Global("JO_JOIN_INDEPANDANCE","LOCALS",10) // Set in PID
	!TriggerOverride(Player1,Range(Player2,100))
	!TriggerOverride(Player1,Range(Player3,100))
	!TriggerOverride(Player1,Range(Player4,100))
	!TriggerOverride(Player1,Range(Player5,100))
	!TriggerOverride(Player1,Range(Player6,100))
THEN
	RESPONSE #100
		SetGlobal("JO_JOIN_IS_INDEPANDANT","LOCALS",1)
		Deactivate(Myself)
END

IF
//
	!Global("JO_JOIN_CUTSCENE","GLOBAL",1) // Don't reactivate if cutscene is in motion
//
	OR(2)
		Global("JO_JOIN_INDEPANDANCE","LOCALS",10) // Set in PID
		Global("JO_JOIN_INDEPANDANCE","LOCALS",0)
//
	OR(6)
		TriggerOverride(Player1,Range(Player2,99))
		TriggerOverride(Player1,Range(Player3,99))
		TriggerOverride(Player1,Range(Player4,99))
		TriggerOverride(Player1,Range(Player5,99))
		TriggerOverride(Player1,Range(Player6,99))
		Global("JO_JOIN_INDEPANDANCE","LOCALS",0)
//
	Global("JO_JOIN_IS_INDEPANDANT","LOCALS",1)
THEN
	RESPONSE #100
		Activate(Myself)
		SetGlobal("JO_JOIN_IS_INDEPANDANT","LOCALS",0)
		Continue()
END

IF // Range 80
//
	!AreaCheck("JO2608")
	Global("JO_JOIN_LOADING","GLOBAL",0)
	NumInPartyGT(1)
	Global("JO_JOIN_INDEPANDANCE","LOCALS",8) // Set in PID
	!TriggerOverride(Player1,Range(Player2,80))
	!TriggerOverride(Player1,Range(Player3,80))
	!TriggerOverride(Player1,Range(Player4,80))
	!TriggerOverride(Player1,Range(Player5,80))
	!TriggerOverride(Player1,Range(Player6,80))
THEN
	RESPONSE #100
		SetGlobal("JO_JOIN_IS_INDEPANDANT","LOCALS",1)
		Deactivate(Myself)
END

IF
//
	!Global("JO_JOIN_CUTSCENE","GLOBAL",1) // Don't reactivate if cutscene is in motion
//
	OR(2)
		Global("JO_JOIN_INDEPANDANCE","LOCALS",8) // Set in PID
		Global("JO_JOIN_INDEPANDANCE","LOCALS",0)
//
	OR(6)
		TriggerOverride(Player1,Range(Player2,79))
		TriggerOverride(Player1,Range(Player3,79))
		TriggerOverride(Player1,Range(Player4,79))
		TriggerOverride(Player1,Range(Player5,79))
		TriggerOverride(Player1,Range(Player6,79))
		Global("JO_JOIN_INDEPANDANCE","LOCALS",0)
//
	Global("JO_JOIN_IS_INDEPANDANT","LOCALS",1)
THEN
	RESPONSE #100
		Activate(Myself)
		SetGlobal("JO_JOIN_IS_INDEPANDANT","LOCALS",0)
		Continue()
END

IF // Range 50
//
	!AreaCheck("JO2608")
	Global("JO_JOIN_LOADING","GLOBAL",0)
	NumInPartyGT(1)
	Global("JO_JOIN_INDEPANDANCE","LOCALS",5) // Set in PID
	!TriggerOverride(Player1,Range(Player2,50))
	!TriggerOverride(Player1,Range(Player3,50))
	!TriggerOverride(Player1,Range(Player4,50))
	!TriggerOverride(Player1,Range(Player5,50))
	!TriggerOverride(Player1,Range(Player6,50))
THEN
	RESPONSE #100
		SetGlobal("JO_JOIN_IS_INDEPANDANT","LOCALS",1)
		Deactivate(Myself)
END

IF
//
	!Global("JO_JOIN_CUTSCENE","GLOBAL",1) // Don't reactivate if cutscene is in motion
//
	OR(2)
		Global("JO_JOIN_INDEPANDANCE","LOCALS",5) // Set in PID
		Global("JO_JOIN_INDEPANDANCE","LOCALS",0)
//
	OR(6)
		TriggerOverride(Player1,Range(Player2,49))
		TriggerOverride(Player1,Range(Player3,49))
		TriggerOverride(Player1,Range(Player4,49))
		TriggerOverride(Player1,Range(Player5,49))
		TriggerOverride(Player1,Range(Player6,49))
		Global("JO_JOIN_INDEPANDANCE","LOCALS",0)
//
	Global("JO_JOIN_IS_INDEPANDANT","LOCALS",1)
THEN
	RESPONSE #100
		Activate(Myself)
		SetGlobal("JO_JOIN_IS_INDEPANDANT","LOCALS",0)
		Continue()
END

IF // Range 30
//
	!AreaCheck("JO2608")
	Global("JO_JOIN_LOADING","GLOBAL",0)
	NumInPartyGT(1)
	Global("JO_JOIN_INDEPANDANCE","LOCALS",3) // Set in PID
	!TriggerOverride(Player1,Range(Player2,30))
	!TriggerOverride(Player1,Range(Player3,30))
	!TriggerOverride(Player1,Range(Player4,30))
	!TriggerOverride(Player1,Range(Player5,30))
	!TriggerOverride(Player1,Range(Player6,30))
THEN
	RESPONSE #100
		SetGlobal("JO_JOIN_IS_INDEPANDANT","LOCALS",1)
		Deactivate(Myself)
END

IF
//
	!Global("JO_JOIN_CUTSCENE","GLOBAL",1) // Don't reactivate if cutscene is in motion
//
	OR(2)
		Global("JO_JOIN_INDEPANDANCE","LOCALS",3) // Set in PID
		Global("JO_JOIN_INDEPANDANCE","LOCALS",0)
//
	OR(6)
		TriggerOverride(Player1,Range(Player2,29))
		TriggerOverride(Player1,Range(Player3,29))
		TriggerOverride(Player1,Range(Player4,29))
		TriggerOverride(Player1,Range(Player5,29))
		TriggerOverride(Player1,Range(Player6,29))
		Global("JO_JOIN_INDEPANDANCE","LOCALS",0)
//
