		FaceObject(PartySlot3)
		IncrementGlobal("JO_JOIN_SWITCHING","GLOBAL",1) // Switching party step 2
		SetGlobal("JO_JOIN_SWITCH_WITH_ME","LOCALS",3) // PartySlot3
		DisplayStringHead(PartySlot3,~Yes ?~)
		ActionOverride(PartySlot3,SetGlobal("JO_JOIN_READY_TO_SWITCH","LOCALS",3)) // active All_in block
		ActionOverride(PartySlot3,SetGlobal("JO_JOIN","LOCALS",1))
		SetInterrupt(TRUE)
END

IF // PartySlot2
	Global("JO_JOIN_SWITCHING","GLOBAL",1) // Switching party step 1
	Global("JO_JOIN_READY_TO_SWITCH","LOCALS",2) // It is my switching party
	Global("JO_JOIN_LOADING","GLOBAL",0) // Don't use this block at loading
	GlobalLT("JO_JOIN_PS_SAFE_SLOT","GLOBAL",2)

	!InPartySlot(PartySlot2,0) // security: not target Player1
	!TriggerOverride(PartySlot2,Global("JO_Myself_Valid","LOCALS",0))
	!TriggerOverride(PartySlot2,Global("JO_JOIN_Wannabe","LOCALS",0))
	OR(2)
		!Global("JO_JOIN_PS_NO_TIMER_DEV","GLOBAL",0)
		!TriggerOverride(PartySlot2,GlobalTimerNotExpired("JO_JOIN_SWITCH_TIMER","LOCALS"))
THEN
	RESPONSE #100
		SetInterrupt(FALSE)
		DisplayString(Myself,~Switching Party !~)
		FaceObject(PartySlot2)
		IncrementGlobal("JO_JOIN_SWITCHING","GLOBAL",1) // Switching party step 2
		SetGlobal("JO_JOIN_SWITCH_WITH_ME","LOCALS",2) // PartySlot2
		DisplayStringHead(PartySlot2,~Hé ?~)
		ActionOverride(PartySlot2,SetGlobal("JO_JOIN_READY_TO_SWITCH","LOCALS",3)) // active All_in block
		ActionOverride(PartySlot2,SetGlobal("JO_JOIN","LOCALS",1))
		SetInterrupt(TRUE)
END

IF // PartySlot1
	Global("JO_JOIN_SWITCHING","GLOBAL",1) // Switching party step 1
	Global("JO_JOIN_READY_TO_SWITCH","LOCALS",2) // It is my switching party
	Global("JO_JOIN_LOADING","GLOBAL",0) // Don't use this block at loading
	GlobalLT("JO_JOIN_PS_SAFE_SLOT","GLOBAL",1)

	!InPartySlot(PartySlot1,0) // security: not target Player1
	!TriggerOverride(PartySlot1,Global("JO_Myself_Valid","LOCALS",0))
	!TriggerOverride(PartySlot1,Global("JO_JOIN_Wannabe","LOCALS",0))
	OR(2)
		!Global("JO_JOIN_PS_NO_TIMER_DEV","GLOBAL",0)
		!TriggerOverride(PartySlot1,GlobalTimerNotExpired("JO_JOIN_SWITCH_TIMER","LOCALS"))
THEN
	RESPONSE #100
		SetInterrupt(FALSE)
		DisplayString(Myself,~Switching Party !~)
		FaceObject(PartySlot1)
		IncrementGlobal("JO_JOIN_SWITCHING","GLOBAL",1) // Switching party step 2
		SetGlobal("JO_JOIN_SWITCH_WITH_ME","LOCALS",1) // PartySlot1
		DisplayStringHead(PartySlot1,~Ho !~)
		ActionOverride(PartySlot1,SetGlobal("JO_JOIN_READY_TO_SWITCH","LOCALS",3)) // active All_in block
		ActionOverride(PartySlot1,SetGlobal("JO_JOIN","LOCALS",1))
		SetInterrupt(TRUE)
END

IF // No slot found because they are safe or members are not wannabe
	Global("JO_JOIN_SWITCHING","GLOBAL",1) // Switching party step 1
	Global("JO_JOIN_READY_TO_SWITCH","LOCALS",2) // It is my switching party
	Global("JO_JOIN_LOADING","GLOBAL",0) // Don't use this block at loading

	OR(3)
		GlobalGT("JO_JOIN_PS_SAFE_SLOT","GLOBAL",5)
		NumInPartyLT(6)
		TriggerOverride(PartySlot6,Global("JO_JOIN_Wannabe","LOCALS",0))
	OR(3)
		GlobalGT("JO_JOIN_PS_SAFE_SLOT","GLOBAL",4)
		NumInPartyLT(5)
		TriggerOverride(PartySlot5,Global("JO_JOIN_Wannabe","LOCALS",0))
	OR(3)
		GlobalGT("JO_JOIN_PS_SAFE_SLOT","GLOBAL",3)
		NumInPartyLT(4)
		TriggerOverride(PartySlot4,Global("JO_JOIN_Wannabe","LOCALS",0))
	OR(3)
		GlobalGT("JO_JOIN_PS_SAFE_SLOT","GLOBAL",2)
		NumInPartyLT(3)
		TriggerOverride(PartySlot3,Global("JO_JOIN_Wannabe","LOCALS",0))
	OR(3)
		GlobalGT("JO_JOIN_PS_SAFE_SLOT","GLOBAL",1)
		NumInPartyLT(2)
		TriggerOverride(PartySlot2,Global("JO_JOIN_Wannabe","LOCALS",0))
	OR(2)
		GlobalGT("JO_JOIN_PS_SAFE_SLOT","GLOBAL",0)
		TriggerOverride(PartySlot1,Global("JO_JOIN_Wannabe","LOCALS",0))
THEN
	RESPONSE #100
		SetGlobal("JO_JOIN_SWITCHING","GLOBAL",0)
		SetGlobal("JO_JOIN_READY_TO_SWITCH","LOCALS",0)
		SetGlobalTimer("JO_JOIN_SWITCH_TIMER","LOCALS",TWO_TURNS)
		DisplayString(Myself,~^0xFF16537eNo party member want to switch with me ? It isn't right...^-~)
END

IF // No slot found
	Global("JO_JOIN_SWITCHING","GLOBAL",1) // Switching party step 1
	Global("JO_JOIN_READY_TO_SWITCH","LOCALS",2) // It is my switching party
	Global("JO_JOIN_LOADING","GLOBAL",0) // Don't use this block at loading
THEN
	RESPONSE #100
		SetGlobal("JO_JOIN_SWITCHING","GLOBAL",0)
		SetGlobal("JO_JOIN_READY_TO_SWITCH","LOCALS",0)
		SetGlobalTimer("JO_JOIN_SWITCH_TIMER","LOCALS",TEN_HOURS) // Will try again in 50 minutes
		DisplayString(Myself,~No party member is available to switch with me, I'm ready when it's possible.~)
END

// Main Switching Party 3

IF // Security block
	Global("JO_JOIN_SWITCHING","GLOBAL",3) // Switching party step 3
	Global("JO_JOIN_READY_TO_SWITCH","LOCALS",2) // It is my switching party
	Global("JO_JOIN_LOADING","GLOBAL",0) // Don't use this block at loading
	!NumInPartyLT(6)
THEN
	RESPONSE #100
		DisplayString(Myself,~^RVoilà qui n'est pas normal... The party is full.^-~)
		Continue()
END

IF // Travelers take place in party
	Global("JO_JOIN_SWITCHING","GLOBAL",3) // Switching party step 3
	Global("JO_JOIN_READY_TO_SWITCH","LOCALS",2) // It is my switching party
	Global("JO_JOIN_LOADING","GLOBAL",0) // Don't use this block at loading
//
	NumInPartyLT(6)
//
	Switch("JO_JOIN_SWITCH_WITH_ME","LOCALS")
THEN
	RESPONSE #1 // PartySlot1
		DisplayStringHead(Myself,~Who is the leader ?~)
		Continue()
	RESPONSE #2 // PartySlot2
		DisplayStringHead(Myself,~Here I go !~)
		Continue()
	RESPONSE #3 // PartySlot3
		DisplayStringHead(Myself,~Back again !~)
		Continue()
	RESPONSE #4 // PartySlot4
		DisplayStringHead(Myself,~Hello there !~)
		Continue()
	RESPONSE #5 // PartySlot5
		DisplayStringHead(Myself,~It's about time.~)
		Continue()
	RESPONSE #6 // PartySlot6
		DisplayStringHead(Myself,~My turn !~)
		Continue()
END


IF // Travelers take place in party
	Global("JO_JOIN_SWITCHING","GLOBAL",3) // Switching party step 3
	Global("JO_JOIN_READY_TO_SWITCH","LOCALS",2) // It is my switching party
	Global("JO_JOIN_LOADING","GLOBAL",0) // Don't use this block at loading
//
	NumInPartyLT(6)
THEN
	RESPONSE #100
		SetInterrupt(FALSE)
		SetGlobal("JO_JOIN","LOCALS",0)
		SetGlobal("JO_JOIN_IS_TRAVELER","LOCALS",0)
		EquipItemEx("JOMINHP1",1)
		SmallWait(1)
		DestroyItem("JOMINHP1")
		SmallWait(1)
		SetInterrupt(TRUE)
		JoinParty()
END


///////////////////////////////////////////////////////////////////////////////

// Fill Party

///////////////////////////////////////////////////////////////////////////////
// Variables :
	// JO_JOIN_Fill_Party (Set by PID or if less than three party member in party)
// Note :
	// Related to JO_JOIN_Move_Around option 15
///////////////////////////////////////////////////////////////////////////////

// Main Fill Party 1

IF
//
	!Global("JO_JOIN_AREA_TRANSITION","GLOBAL",1) 
//
	Global("JO_JOIN_LOADING","GLOBAL",0) // Don't use this block at loading
	Global("JO_JOIN_RETURN_SLOT","GLOBAL",0)
	Global("JO_JOIN_SWITCHING","GLOBAL",0) // Don't use this block when Switching Party
	Global("JO_JOIN_LEAVING_PARTY","GLOBAL",0) // Don't use this block when Leave Party
//
//	!Global("JO_JOIN_IS_JOINING","LOCALS",0) // Why ?
	OR(2)
		Global("JO_JOIN_Fill_Party","LOCALS",1)
		NumInPartyLT(3) // Come in party if less than 3 party members
//
	!Global("JO_JOIN_Fill_Party","LOCALS",2) // Prevent boucle due to previous OR(2) above
	// add Continue() below, it should make this one useless but could allow mor than one traveler to fill party
	Global("JO_NOJOIN","GLOBAL",0)
//
	!InPartyAllowDead(PartySlot6)
//
	ActionListEmpty()
	!ActuallyInCombat()
	!See([ENEMY])
//
	Global("JO_Myself_Valid","LOCALS",1)
//
	OR(3)
		Allegiance(Myself,FAMILIAR)
		Allegiance(Myself,CONTROLLED)
		!Global("JO_JOIN_IS_TRAVELER","LOCALS",0)
//
	Global("JO_JOIN_CUTSCENE","GLOBAL",0)
	Global("JO_JOIN","LOCALS",0)
	Global("JO_JOINI","LOCALS",0)
	Global("JO_JOIN_NEVER_JOIN","LOCALS",0)
	!Global("JO_JOIN_NEVER_FILL","LOCALS",1)
THEN
	RESPONSE #25
		SetGlobal("JO_NOJOIN_LOCALS","LOCALS",1)
		SetGlobal("JO_NOJOIN","GLOBAL",1)
		SetGlobal("JO_JOIN_Fill_Party","LOCALS",2)
		DisplayStringHead(Myself,~Let me in !~)
		Continue()
	RESPONSE #25
		SetGlobal("JO_NOJOIN_LOCALS","LOCALS",1)
		SetGlobal("JO_NOJOIN","GLOBAL",1)
		SetGlobal("JO_JOIN_Fill_Party","LOCALS",2)
		DisplayStringHead(Myself,~Incoming !~)
		Continue()
	RESPONSE #25
		SetGlobal("JO_NOJOIN_LOCALS","LOCALS",1)
		SetGlobal("JO_NOJOIN","GLOBAL",1)
		SetGlobal("JO_JOIN_Fill_Party","LOCALS",2)
		DisplayStringHead(Myself,~There is plenty of room in this group...~)
		Continue()
	RESPONSE #25
		SetGlobal("JO_NOJOIN_LOCALS","LOCALS",1)
		SetGlobal("JO_NOJOIN","GLOBAL",1)
		SetGlobal("JO_JOIN_Fill_Party","LOCALS",2)
		DisplayStringHead(Myself,~Is it warm in here ?~)
		Continue()
END

// Main Fill Party 2

IF
//
	Global("JO_JOIN_LOADING","GLOBAL",0) // Don't use this block at loading
	Global("JO_JOIN_RETURN_SLOT","GLOBAL",0)
//
	Global("JO_JOIN_Fill_Party","LOCALS",2)
//		ActionListEmpty()
//		!ActuallyInCombat()
//		!See([ENEMY])
//
	Global("JO_Myself_Valid","LOCALS",1)
//
	OR(3)
		Allegiance(Myself,FAMILIAR)
		Allegiance(Myself,CONTROLLED)
		!Global("JO_JOIN_IS_TRAVELER","LOCALS",0)
//
	NumInPartyLT(6)
THEN
	RESPONSE #100
		SetInterrupt(FALSE)
		SetGlobal("JO_JOIN","LOCALS",0)
		SetGlobal("JO_NOJOIN","GLOBAL",0)
		SetGlobal("JO_NOJOIN_LOCALS","LOCALS",0)
		SetGlobal("JO_JOIN_Fill_Party","LOCALS",0)
		SetGlobal("JO_JOIN_IS_TRAVELER","LOCALS",0)
		SetGlobalTimer("JO_JOIN_SWITCH_TIMER","LOCALS",ONE_DAY)
		SetGlobalTimer("JO_JOIN_JOIN_TIMER","LOCALS",TWO_DAYS)
		SmallWait(1)
		EquipItemEx("JOMINHP1",1)
		SmallWait(1)
		DestroyItem("JOMINHP1")
		SmallWait(2)
//		RemoveFamiliar()
		SetInterrupt(TRUE)
		JoinParty()
END

// Secondary Fill Party 1 // If other travelers integer the party and don't let enough room for this one

IF
	!Global("JO_JOIN_Fill_Party","LOCALS",0)
//
	Global("JO_Myself_Valid","LOCALS",1)
//
	OR(3)
		Allegiance(Myself,FAMILIAR)
		Allegiance(Myself,CONTROLLED)
		!Global("JO_JOIN_IS_TRAVELER","LOCALS",0)
//
	NumInPartyGT(5)
THEN
	RESPONSE #100
		SetInterrupt(FALSE)
		DisplayStringHead(Myself,~Too slow...~)
		SetGlobal("JO_JOIN","LOCALS",0)
		SetGlobal("JO_NOJOIN","GLOBAL",0)
		SetGlobal("JO_NOJOIN_LOCALS","LOCALS",0)
		SetGlobal("JO_JOIN_Fill_Party","LOCALS",0)
		SetInterrupt(TRUE)
		Continue()
END

// Secondary Fill Party 1 // Reset variable

IF
	OR(2)
		InParty(Myself)
		Allegiance(Myself,PC)
//
	!Global("JO_JOIN_Fill_Party","LOCALS",0)
THEN
	RESPONSE #100
		SetGlobal("JO_JOIN","LOCALS",0)
		SetGlobal("JO_NOJOIN","GLOBAL",0)
		SetGlobal("JO_NOJOIN_LOCALS","LOCALS",0)
		SetGlobal("JO_JOIN_Fill_Party","LOCALS",0)
		SetGlobal("JO_JOIN_IS_TRAVELER","LOCALS",0)
		SetGlobalTimer("JO_JOIN_SWITCH_TIMER","LOCALS",ONE_DAY)
		Continue()
END

