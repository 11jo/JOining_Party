///////////////////////////////////////////////////////////////////////////////

// Loading Switch

///////////////////////////////////////////////////////////////////////////////
// Variables :
	// JO_JOIN_LOADING (Launch Loading Switch script/CutSceneLite)
		// JO_JOIN_LOADING_PLAYER (Check if party member are deactivated)
			// JO_JOIN_LOAD (Used by travelers loading steps)
///////////////////////////////////////////////////////////////////////////////


// For Party member After Main Loading Switch 1 //

IF
//
	Global("JO_JOIN_LOADING","GLOBAL",1)
	Global("JO_JOIN_LOAD_PARTY_WAIT","GLOBAL",0) // Set to 1 by the first travelers switch
	!TriggerOverride(Player1,GlobalGT("JO_JOIN_LOADING_PLAYER","LOCALS",0)) // Check if another party member already leave
//
	Global("JO_JOIN_LOADING_PLAYER","LOCALS",0)
	IsActive(Myself) // Same as Global("JO_JOIN_LOADING_PLAYER","LOCALS",0)
//
	InParty(Myself)
	NumInPartyGT(5)
	Global("JO_JOIN_LOAD","LOCALS",0) // Not a traveler switching at loading
	!Global("JO_JOINI","LOCALS",1) // Not a traveler switching at loading
	!Dead("%Death_var%")
THEN
	RESPONSE #30
		ActionOverride(Player1,IncrementGlobal("JO_JOIN_LOADING_PLAYER","LOCALS",1))
		SetGlobal("JO_JOIN_LOADING_PLAYER","LOCALS",1)
		DisplayStringHead(Myself,~Oh no ! More Travelers...~)
		LeaveParty()
		Deactivate(Myself)
		Continue()
	RESPONSE #20
		NoAction()
	RESPONSE #20
		NoAction()
	RESPONSE #20
		NoAction()
	RESPONSE #10
		NoAction()
END

// For party member After Main Loading Switch 3 //

IF
//
	Global("JO_JOIN_LOADING_PLAYER","LOCALS",1) // Is deactivated
	!Global("JO_JOIN_LOADING","GLOBAL",1) // Loading switch "almost" finished
//
	NumInPartyLT(6)
THEN
	RESPONSE #100
		ActionOverride(Player1,IncrementGlobal("JO_JOIN_LOADING_PLAYER","LOCALS",-1))
		SetGlobal("JO_JOIN_LOADING_PLAYER","LOCALS",0)
		Activate(Myself)
		DisplayStringHead(Myself,~I'm back !~)
		JoinParty()
		Continue()
END

// For Traveler After Main Loading Switch 3

IF
	Global("JO_JOIN_LOAD","LOCALS",3)
	Global("JO_JOIN_LOADING","GLOBAL",0)
THEN
	RESPONSE #100
		SetGlobal("JO_JOIN_LOAD","LOCALS",0)
END

///////////////////////////////////////////////////////////////////////////////

// Fill Party

///////////////////////////////////////////////////////////////////////////////
// Note :
	// Secure variables from Fill Party in JO_JOINI.BAF
///////////////////////////////////////////////////////////////////////////////


IF
//
	Global("JO_JOIN_LOADING","GLOBAL",0) // Don't use this block at loading
//
	InParty(Myself)
	!Global("JO_JOIN_Fill_Party","LOCALS",0)
THEN
	RESPONSE #100
		SetInterrupt(FALSE)
		SetGlobal("JO_JOIN_IS_JOINING","LOCALS",0)
		SetGlobal("JO_JOIN_Fill_Party","LOCALS",0)
		SetInterrupt(TRUE)
		Continue()
END

///////////////////////////////////////////////////////////////////////////////

// Wannabe : NPC can be traveler

///////////////////////////////////////////////////////////////////////////////
// Variables :
	// JO_JOIN_Wannabe (If set to 1 the NPC is available to be a traveler Can be changed in PID)
// Note :
	// A party member available to be traveler
///////////////////////////////////////////////////////////////////////////////

IF
	Global("JO_JOIN_Wannabe","LOCALS",0)
	InParty(Myself)
	Global("JO_JOIN_IS_Wannabe","LOCALS",0) // Only once
THEN
	RESPONSE #100
		SetGlobal("JO_JOIN_IS_Wannabe","LOCALS",1)
		SetGlobal("JO_JOIN_Wannabe","LOCALS",1)
		SetGlobalTimer("JO_JOIN_SWITCH_TIMER","LOCALS",ONE_DAY)
		Continue()
END

///////////////////////////////////////////////////////////////////////////////

// Switching Party

///////////////////////////////////////////////////////////////////////////////
// Variables :
	// JO_JOIN_SWITCH_TIMER (Timer make sure the NPC stay long enough in party)
		// JO_JOIN_SWITCH_WITH_ME (If set to 1 then the party member is available for switching with a traveler)
			// JO_JOIN_READY_TO_SWITCH (After some time in party, a party member can echange place with a traveler)
				// JO_JOIN_Wannabe (Party member eligible and willing to be traveler)
// Note :
	// Related to Switching party in JO_JOINI.baf
		// Reset globals and set JO_JOIN_SWITCH_TIMER randomly
			// TODO : Setting JO_JOIN_SWITCH_TIMER randomly collision with the component "Switching Party Timer" at the moment
///////////////////////////////////////////////////////////////////////////////

// Related to Switching party !!!

/*
// NEW
// TODO : add in dialog to let players decide if the party member should stay in party for while
IF
//
	Global("JO_JOIN_LOADING","GLOBAL",0) // Don't use this block at loading
	!Global("JO_JOIN_TRAVELER_NumInParty","GLOBAL",0) // Should prevent Loading switch if no traveler exists
//
	!GlobalTimerNotExpired("JO_JOIN_DELAY_SWITCH_TIMER","LOCALS")
//
	Global("JO_JOIN_READY_TO_SWITCH","LOCALS",0)
	Global("JO_JOIN_NEVER_SWITCH","LOCALS",0)
	Global("JO_Myself_Valid","LOCALS",1)
//
	Switch("JO_JOIN_DELAY_SWITCH","LOCALS")
THEN
	RESPONSE #0
		SetGlobalTimer("JO_JOIN_DELAY_SWITCH_TIMER","LOCALS",ONE_TURN)
		Continue()
	RESPONSE #1
		SetGlobalTimer("JO_JOIN_DELAY_SWITCH_TIMER","LOCALS",ONE_DAY)
		Continue()
	RESPONSE #2
		SetGlobalTimer("JO_JOIN_DELAY_SWITCH_TIMER","LOCALS",TWO_DAYS)
		Continue()
	RESPONSE #3
		SetGlobalTimer("JO_JOIN_DELAY_SWITCH_TIMER","LOCALS",THREE_DAYS)
		Continue()
	RESPONSE #4
		SetGlobalTimer("JO_JOIN_DELAY_SWITCH_TIMER","LOCALS",FOUR_DAYS)
		Continue()
	RESPONSE #5
		SetGlobalTimer("JO_JOIN_DELAY_SWITCH_TIMER","LOCALS",FIVE_DAYS)
		Continue()
	RESPONSE #6
		SetGlobalTimer("JO_JOIN_DELAY_SWITCH_TIMER","LOCALS",SIX_DAYS)
		Continue()
	RESPONSE #7
		SetGlobalTimer("JO_JOIN_DELAY_SWITCH_TIMER","LOCALS",SEVEN_DAYS)
		Continue()
END

// TODO : add  (!GlobalTimerNotExpired("JO_JOIN_DELAY_SWITCH_TIMER","LOCALS")) in next IF block

// TODO : add  (SetGlobalTimer("JO_JOIN_DELAY_SWITCH_TIMER","LOCALS",ONE_ROUND) in next REPONSE block (to be sur it reset)
// TODO : Also add  (SetGlobalTimer("JO_JOIN_DELAY_SWITCH_TIMER","LOCALS",ONE_ROUND) when a party member become traveler (to be sur it reset)
*/

// Primary Switching Party 1

IF // If "JO_JOIN_READY_TO_SWITCH","LOCALS",1 then the NPC is available for a Switching Party
//
	Global("JO_JOIN_LOADING","GLOBAL",0) // Don't use this block at loading
	!Global("JO_JOIN_TRAVELER_NumInParty","GLOBAL",0) // Should prevent Loading switch if no traveler exists
//
	!GlobalTimerNotExpired("JO_JOIN_SWITCH_TIMER","LOCALS") // Timer make sure the party member stay long enough in party
	Global("JO_JOIN_READY_TO_SWITCH","LOCALS",0)
	Global("JO_JOIN_NEVER_SWITCH","LOCALS",0)
	Global("JO_Myself_Valid","LOCALS",1)
THEN
	RESPONSE #100
		SetGlobal("JO_JOIN_READY_TO_SWITCH","LOCALS",1)
		DisplayString(Myself,~Ready to Switching Party when it's possible.~)
		Continue()
END

///////////////////////////////////////////////////////////////////////////////

// Main Switching Party 4 // (Previous part are in JO_JOINI.BAF)

IF // After Switching Party with a party member Reset JO_NOJOIN and set JO_JOIN_SWITCH_TIMER, and other related variables
//
	OR(2)
		!Global("JO_NOJOIN_LOCALS","LOCALS",0)
		!Global("JO_JOIN_SWITCH_WITH_ME","LOCALS",0)
//
	InParty(Myself)
//
	!Global("JO_JOINI","LOCALS",1) // Make sure we are InParty for good
	Global("JO_Myself_LeaveParty","LOCALS",0) // Make sure we are InParty for good
	Global("JO_%Death_var%_LeaveParty","GLOBAL",0) // Make sure we are InParty for good
THEN
	RESPONSE #25
		SetInterrupt(FALSE)
		SetGlobal("JO_JOIN_SWITCHING","GLOBAL",0)
		SetGlobal("JO_NOJOIN","GLOBAL",0)
		SetGlobal("JO_NOJOIN_LOCALS","LOCALS",0)
		SetGlobal("JO_JOIN_READY_TO_SWITCH","LOCALS",0)
		SetGlobalTimer("JO_JOIN_SWITCH_TIMER","LOCALS",ONE_DAY)
		SetGlobal("JO_JOIN_SWITCH_WITH_ME","LOCALS",0)
		SetInterrupt(TRUE)
		Continue()
	RESPONSE #25
		SetInterrupt(FALSE)
		SetGlobal("JO_JOIN_SWITCHING","GLOBAL",0)
		SetGlobal("JO_NOJOIN","GLOBAL",0)
		SetGlobal("JO_NOJOIN_LOCALS","LOCALS",0)
		SetGlobal("JO_JOIN_READY_TO_SWITCH","LOCALS",0)
		SetGlobalTimer("JO_JOIN_SWITCH_TIMER","LOCALS",TWO_DAYS)
		SetGlobal("JO_JOIN_SWITCH_WITH_ME","LOCALS",0)
		SetInterrupt(TRUE)
		Continue()
	RESPONSE #25
		SetInterrupt(FALSE)
		SetGlobal("JO_JOIN_SWITCHING","GLOBAL",0)
		SetGlobal("JO_NOJOIN","GLOBAL",0)
		SetGlobal("JO_NOJOIN_LOCALS","LOCALS",0)
		SetGlobal("JO_JOIN_READY_TO_SWITCH","LOCALS",0)
		SetGlobalTimer("JO_JOIN_SWITCH_TIMER","LOCALS",TWELVE_HOURS)
		SetGlobal("JO_JOIN_SWITCH_WITH_ME","LOCALS",0)
		SetInterrupt(TRUE)
		Continue()
	RESPONSE #25
		SetInterrupt(FALSE)
		SetGlobal("JO_JOIN_SWITCHING","GLOBAL",0)
		SetGlobal("JO_NOJOIN","GLOBAL",0)
		SetGlobal("JO_NOJOIN_LOCALS","LOCALS",0)
		SetGlobal("JO_JOIN_READY_TO_SWITCH","LOCALS",0)
		SetGlobalTimer("JO_JOIN_SWITCH_TIMER","LOCALS",EIGHTEEN_HOURS)
		SetGlobal("JO_JOIN_SWITCH_WITH_ME","LOCALS",0)
		SetInterrupt(TRUE)
		Continue()
END

///////////////////////////////////////////////////////////////////////////////

// Leave Party

///////////////////////////////////////////////////////////////////////////////
// Variables :
	// JO_JOIN_LEAVE_PARTY (For party member that make place an instant for the traveler if party is full)
		// JO_Myself_LeaveParty (Set by PID to make a traveler leave regulary)
// Note :
	// Make traveler reintegrate the group for leaving regulary as party member.
	 // JO_JOIN_LEAVE_PARTY is also used by the traveler to avoid several party member to make place.
///////////////////////////////////////////////////////////////////////////////

// Secondary Leave Party 1

IF // Selected party member to make room
	Global("JO_JOIN_LOADING","GLOBAL",0) // Don't use this block at loading
	Global("JO_JOIN_SWITCHING","GLOBAL",0) // Don't use this block when Switching Party
	InParty(Myself)
	!InPartySlot(Myself,0)
//
	Global("JO_JOIN_LEAVE_PARTY","LOCALS",1)
THEN
	RESPONSE #100
		SetInterrupt(FALSE)
		SetGlobal("JO_JOIN_LEAVE_PARTY","LOCALS",2)
		LeaveParty()
		SmallWait(1)
		GiveItemCreate("JOMINHP1",Myself,0,0,0)
//		SmallWait(1)
		EquipItemEx("JOMINHP1",0)
//		SmallWait(1)
		ChangeEnemyAlly(Myself,FAMILIAR)
		AddFamiliar()
		FaceObject(Player1)
		SetGlobal("JO_TRAVELER_%Death_var%","GLOBAL",1)
		SetGlobal("JO_JOIN_IS_TRAVELER","LOCALS",1)
		DisplayStringHead(Myself,~Oh no ! Less travelers~)
		ChangeAIScript("JO_JOINI",GENERAL)
		SetInterrupt(TRUE)
		Continue()
END


// No Wannabe in party

IF // If no party member are available to be traveler the Player need to make some available.
//
	Global("JO_JOIN_LOADING","GLOBAL",0) // Don't use this block at loading
	Global("JO_JOIN_SWITCHING","GLOBAL",0) // Don't use this block when Switching Party
//
	NumInPartyGT(5)
	OR(2)
		!Global("JO_Myself_LeaveParty","LOCALS",0)
		!Global("JO_%Death_var%_LeaveParty","GLOBAL",0)
//
	!Global("JO_Myself_Valid","LOCALS",0)
	OR(3)
		Allegiance(Myself,FAMILIAR)
		Allegiance(Myself,CONTROLLED)
		!Global("JO_JOIN_IS_TRAVELER","LOCALS",0)
//
	!TriggerOverride(Player6,Global("JO_JOIN_Wannabe","LOCALS",1))
	!TriggerOverride(Player5,Global("JO_JOIN_Wannabe","LOCALS",1))
	!TriggerOverride(Player4,Global("JO_JOIN_Wannabe","LOCALS",1))
	!TriggerOverride(Player3,Global("JO_JOIN_Wannabe","LOCALS",1))
	!TriggerOverride(Player2,Global("JO_JOIN_Wannabe","LOCALS",1))
// 	!TriggerOverride(Player6,Global("JO_Myself_Valid","LOCALS",0)) // TODO : See below, but this block could be expanded to take party member not valid in consideration.
//	RandomNum(5,2)
THEN
	RESPONSE #100
		SetInterrupt(FALSE)
		DisplayStringHead(Myself,~No party member can make room for me ? We need to change that.~)
		SetGlobal("JO_Myself_LeaveParty","LOCALS",0)
		SetGlobal("JO_%Death_var%_LeaveParty","LOCALS",0)
		SetInterrupt(TRUE)
END

