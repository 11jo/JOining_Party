// Block wait 1 // Secondary Leave Party 1

IF // Temporise to avoid that more than one traveler try to switch
//
	Global("JO_JOIN_LOADING","GLOBAL",0) // Don't use this block at loading
	Global("JO_JOIN_LEAVE_WAIT","LOCALS",0)
	OR(2)
		Global("JO_JOIN_LEAVING_PARTY","GLOBAL",0)
		Global("JO_JOIN_LEAVE_PARTY","LOCALS",1)
	OR(2)
		Global("JO_NOJOIN","GLOBAL",0)
		Global("JO_JOIN_LEAVE_PARTY","LOCALS",1)
//
	NumInPartyLT(6)
	OR(2)
		!Global("JO_Myself_LeaveParty","LOCALS",0)
		!Global("JO_%Death_var%_LeaveParty","GLOBAL",0)
	!Global("JO_Myself_Valid","LOCALS",0)
	OR(3)
		Allegiance(Myself,FAMILIAR)
		Allegiance(Myself,CONTROLLED)
		!Global("JO_JOIN_IS_TRAVELER","LOCALS",0)
THEN
	RESPONSE #100
		SetInterrupt(FALSE)
		SetGlobal("JO_JOIN_LEAVE_WAIT","LOCALS",1)
		DisplayString(Myself,~Waiting to Leave Party.~)
		SetInterrupt(TRUE)
END

// Block wait 2 // Secondary Leave Party 1

IF // After block wait 1 if everything is in order, let's switch !
//
	Global("JO_JOIN_LOADING","GLOBAL",0) // Don't use this block at loading
	Global("JO_JOIN_LEAVE_WAIT","LOCALS",1)
	OR(2)
		Global("JO_JOIN_LEAVING_PARTY","GLOBAL",0)
		Global("JO_JOIN_LEAVE_PARTY","LOCALS",1)
	OR(2)
		Global("JO_NOJOIN","GLOBAL",0)
		Global("JO_JOIN_LEAVE_PARTY","LOCALS",1)
//
	NumInPartyLT(6)
	OR(2)
		!Global("JO_Myself_LeaveParty","LOCALS",0)
		!Global("JO_%Death_var%_LeaveParty","GLOBAL",0)
	!Global("JO_Myself_Valid","LOCALS",0)
	OR(3)
		Allegiance(Myself,FAMILIAR)
		Allegiance(Myself,CONTROLLED)
		!Global("JO_JOIN_IS_TRAVELER","LOCALS",0)
THEN
	RESPONSE #100
		SetInterrupt(FALSE)
		SetGlobal("JO_JOIN_LEAVE_WAIT","LOCALS",2)
		DisplayString(Myself,~Leave Party !~)
		SetInterrupt(TRUE)
END

// Secondary Leave Party 2

IF // If something arise we reset to make the traveler go back to Main Leave Party 1
//
	Global("JO_JOIN_LOADING","GLOBAL",0) // Don't use this block at loading
	Global("JO_JOIN_LEAVE_PARTY","LOCALS",1)
//
	NumInPartyGT(5)
	OR(2)
		!Global("JO_Myself_LeaveParty","LOCALS",0)
		!Global("JO_%Death_var%_LeaveParty","GLOBAL",0)
	!Global("JO_Myself_Valid","LOCALS",0)
	OR(3)
		Allegiance(Myself,FAMILIAR)
		Allegiance(Myself,CONTROLLED)
		!Global("JO_JOIN_IS_TRAVELER","LOCALS",0)
THEN
	RESPONSE #100
		SetGlobal("JO_JOIN_LEAVE_PARTY","LOCALS",0)
		DisplayString(Myself,~I Leave Party in a moment...~)
END

// Main Leave Party 2

IF // If / When party isn't full, come in party
//
	Global("JO_JOIN_LOADING","GLOBAL",0) // Don't use this block at loading
	OR(2)
		Global("JO_JOIN_LEAVING_PARTY","GLOBAL",0)
		Global("JO_JOIN_LEAVE_PARTY","LOCALS",1)
	OR(2)
		Global("JO_NOJOIN","GLOBAL",0)
		Global("JO_JOIN_LEAVE_PARTY","LOCALS",1)
//
	NumInPartyLT(6)
	OR(2)
		!Global("JO_Myself_LeaveParty","LOCALS",0)
		!Global("JO_%Death_var%_LeaveParty","GLOBAL",0)
	!Global("JO_Myself_Valid","LOCALS",0)
	OR(3)
		Allegiance(Myself,FAMILIAR)
		Allegiance(Myself,CONTROLLED)
		!Global("JO_JOIN_IS_TRAVELER","LOCALS",0)
THEN
	RESPONSE #100
		SetInterrupt(FALSE)
		SetGlobal("JO_NOJOIN_LOCALS","LOCALS",1)
		SetGlobal("JO_NOJOIN","GLOBAL",1)
		SetGlobal("JO_JOIN_LEAVE_WAIT","LOCALS",0)
		SetGlobal("JO_JOIN_LEAVE_PARTY","LOCALS",0)
		SetGlobal("JO_JOIN_NEVER_JOIN","LOCALS",0)
		SetGlobal("JO_JOIN_NEVER_SWITCH","LOCALS",0)
		SetGlobal("JO_TRAVELER_%Death_var%","GLOBAL",0)
		SetGlobal("JO_JOIN_IS_TRAVELER","LOCALS",0)
		SetGlobal("JO_JOIN_IS_JOINING","LOCALS",0)
		SetGlobal("JO_JOIN","LOCALS",0)
		SetGlobal("JO_JOINI","LOCALS",0)
		SetGlobal("JO_JOIN_Move_Done","LOCALS",0)
		SmallWait(1)
		EquipItemEx("JOMINHP1",1)
		SmallWait(1)
		DestroyItem("JOMINHP1")
		SmallWait(1)
		SetInterrupt(TRUE)
		JoinPartyOverride()
END

// Main Leave Party 3

IF // Then leave party the regular way.
//
	Global("JO_JOIN_LOADING","GLOBAL",0) // Don't use this block at loading
//
	OR(2)
		!Global("JO_Myself_LeaveParty","LOCALS",0)
		!Global("JO_%Death_var%_LeaveParty","GLOBAL",0)
	Allegiance(Myself,PC)
	!InPartySlot(Myself,0)
	Switch("JO_JOIN_LEAVING_PARTY","GLOBAL") // Set to 1 when a party member need to make room
THEN
	RESPONSE #0
		SetInterrupt(FALSE)
		SetGlobal("JO_Myself_LeaveParty","LOCALS",0)
		SetGlobal("JO_%Death_var%_LeaveParty","GLOBAL",0)
		SetGlobal("JO_Myself_AllowDead","LOCALS",0)
		SetGlobal("JO_Myself_InParty","LOCALS",0)
		SetGlobal("JO_Myself_Valid","LOCALS",0)
		DisplayStringHead(Myself,~Farewell...~)
		SetGlobal("JO_NOJOIN","GLOBAL",0) // In case there was ne need to a party member to make room
		SetGlobal("JO_NOJOIN_LOCALS","LOCALS",0)
		LeaveParty()
		SetInterrupt(TRUE)
		Continue()
	RESPONSE #1
		SetInterrupt(FALSE)
		SetGlobal("JO_Myself_LeaveParty","LOCALS",0)
		SetGlobal("JO_%Death_var%_LeaveParty","GLOBAL",0)
		SetGlobal("JO_Myself_AllowDead","LOCALS",0)
		SetGlobal("JO_Myself_InParty","LOCALS",0)
		SetGlobal("JO_Myself_Valid","LOCALS",0)
		DisplayStringHead(Myself,~Farewell...~)
		LeaveParty()
		SetInterrupt(TRUE)
		Continue()
END

// Secondary Leave Party 2

IF // Reintegrate the party member in party
//
	Global("JO_JOIN_LOADING","GLOBAL",0) // Don't use this block at loading
	Global("JO_JOIN_SWITCHING","GLOBAL",0)
//
	OR(3)
		Allegiance(Myself,FAMILIAR)
		Allegiance(Myself,CONTROLLED)
		!Global("JO_JOIN_IS_TRAVELER","LOCALS",0)
	NumInPartyLT(6)
	Global("JO_JOIN_LEAVE_PARTY","LOCALS",2)
THEN
	RESPONSE #100
		SetInterrupt(FALSE)
		SetGlobal("JO_JOIN","LOCALS",0)
		SetGlobal("JO_JOIN_IS_TRAVELER","LOCALS",0)
		SetGlobal("JO_JOIN_LEAVING_PARTY","GLOBAL",0)
		SetGlobal("JO_JOIN_LEAVE_PARTY","LOCALS",0)
		SetGlobalTimer("JO_JOIN_SWITCH_TIMER","LOCALS",ONE_DAY)
		SmallWait(1)
		EquipItemEx("JOMINHP1",1)
		SmallWait(1)
		DestroyItem("JOMINHP1")
		SmallWait(2)
		DisplayStringHead(Myself,~I'm back !~)
		SetGlobal("JO_NOJOIN","GLOBAL",0) // When a party member retrieve is place
		SetGlobal("JO_NOJOIN_LOCALS","LOCALS",0)
		SetInterrupt(TRUE)
		JoinParty()
END

///////////////////////////////////////////////////////////////////////////////

// Security

///////////////////////////////////////////////////////////////////////////////

// Cas d'un recrutement non standard (ctrl+Q par exemple)
IF
//
	Global("JO_JOIN_LOADING","GLOBAL",0) // Don't use this block at loading
//
	!Global("JO_JOIN_IS_TRAVELER","LOCALS",0)
	Global("JO_JOINI","LOCALS",0)
	InParty(Myself)
THEN
	RESPONSE #100
		SetGlobal("JO_JOIN_IS_TRAVELER","LOCALS",0)
END

///////////////////////////////////////////////////////////////////////////////

// Cas où le script serait quand même actif mais que le personnage ne répond à aucun cas répertorié :
// ni dans le groupe, ni familier, ni au sol, ni charmé
// ChangeEnemyAlly par exemple
IF
//
	Global("JO_JOIN_LOADING","GLOBAL",0) // Don't use this block at loading
//
	!Global("JO_JOIN_IS_TRAVELER","LOCALS",0)
	!StateCheck(Myself,STATE_CHARMED)
	!Allegiance(Myself,FAMILIAR)
	!Allegiance(Myself,CONTROLLED)
	!InParty(Myself)
	!Global("JO_JOINI","LOCALS",1) // TODO: Added
	OR(2)
		!Allegiance(Myself,NEUTRAL)
		Global("JO_JOIN_SLEEPING_DEAD","LOCALS",0)
THEN
	RESPONSE #100
		// reset block
		SetGlobal("JO_JOIN_IS_TRAVELER","LOCALS",0)
		SetGlobal("JO_Myself_LeaveParty","LOCALS",0)
		SetGlobal("JO_%Death_var%_LeaveParty","GLOBAL",0)
		SetGlobal("JO_JOIN_IS_JOINING","LOCALS",0)
		SetGlobal("JO_JOIN","LOCALS",0)
		SetGlobal("JO_JOINI","LOCALS",0)
		// end reset block
END

///////////////////////////////////////////////////////////////////////////////

IF
//
	Global("JO_JOIN_LOADING","GLOBAL",0) // Don't use this block at loading
//
	OR(3)
		Allegiance(Myself,FAMILIAR)
		Allegiance(Myself,CONTROLLED)
		!Global("JO_JOIN_IS_TRAVELER","LOCALS",0)
	Global("JO_TRAVELER_%Death_var%","GLOBAL",0)
THEN
	RESPONSE #100
		SetGlobal("JO_TRAVELER_%Death_var%","GLOBAL",1)
END

///////////////////////////////////////////////////////////////////////////////

IF
//
	Global("JO_JOIN_LOADING","GLOBAL",0) // Don't use this block at loading
//
	!AreaCheck("BD0120")
	Global("JO_JOIN_SLEEPING_DEAD","LOCALS",0)
	OR(2)
		!Allegiance(Myself,FAMILIAR)
		InParty(Myself)
	OR(2)
		!Allegiance(Myself,CONTROLLED)
		InParty(Myself)
	OR(3)
		!Global("JO_TRAVELER_%Death_var%","GLOBAL",0)
		!Global("JO_Myself_LeaveParty","LOCALS",0)
		!Global("JO_%Death_var%_LeaveParty","GLOBAL",0)
	Global("JO_JOIN","LOCALS",0)
	Global("JO_JOINI","LOCALS",0)
THEN
	RESPONSE #100
		SetGlobal("JO_TRAVELER_%Death_var%","GLOBAL",0)
		SetGlobal("JO_Myself_LeaveParty","LOCALS",0)
		SetGlobal("JO_%Death_var%_LeaveParty","GLOBAL",0)
		SetGlobal("JO_JOIN_IS_JOINING","LOCALS",0)
END

///////////////////////////////////////////////////////////////////////////////

// Related to Join_ability.baf destroy item before

IF // TODO : Seem to execute several times when a traveler reintegrate the party...
//
	Global("JO_JOIN_LOADING","GLOBAL",0) // Don't use this block at loading
//
	!Allegiance(Myself,FAMILIAR)
	!Allegiance(Myself,CONTROLLED)
	HasItem("JOMINHP1",Myself)
	Global("JO_JOIN_SLEEPING_DEAD","LOCALS",0)
	Global("JO_JOIN","LOCALS",0)
	Global("JO_JOINI","LOCALS",0)
THEN
	RESPONSE #100
		EquipItemEx("JOMINHP1",1)
		SmallWait(1)
		DestroyItem("JOMINHP1")
END

///////////////////////////////////////////////////////////////////////////////

// Check if traveler are in party

///////////////////////////////////////////////////////////////////////////////
// Variables :
	// JO_JOIN_TRAVELER_NumInParty (Check if a least one traveler is present)
// Special
	// REPLACE TRAVELER NumInParty (Expanded at installation by JOining_Party_Select_End.tph)
// Note :
	// Related to BD0120.bcs and maybe other transitions (see JOining_Party_Select_End.tph)
		// Disable the Loading Switch if no traveler are her
			// Related block in JO_JOINP
///////////////////////////////////////////////////////////////////////////////

// Have a variable that say "at least one traveler is here"
IF
//
	Global("JO_JOIN_LOADING","GLOBAL",0) // Don't use this block at loading
	OR(3)
		Allegiance(Myself,FAMILIAR)
		Allegiance(Myself,CONTROLLED)
		!Global("JO_JOIN_IS_TRAVELER","LOCALS",0)
	Global("JO_JOIN_TRAVELER_NumInParty","GLOBAL",0)
THEN
	RESPONSE #100
		SetGlobal("JO_JOIN_TRAVELER_NumInParty","GLOBAL",1)
END

///////////////////////////////////////////////////////////////////////////////

// Traveler !

///////////////////////////////////////////////////////////////////////////////
// Variables :
	// JO_JOIN_SWITCH_TIMER (Timer for starting for Switching Party)
			// JO_NOJOIN (Check if no traveler is currently switching)
				// JO_JOIN_TALK (Used to display string We are now fellow travelers.)
					// JO_JOIN_NEVER_JOIN (Prevent Quick Switch and Fill Party)
						// JO_JOIN_NEVER_SWITCH (Prevent the Switching Party)
							// JO_JOIN_NEVER_BANTER (Prevent lauching banters)
								// JO_JOIN (Used to make a party member a traveler)
									// JO_JOIN_IS_TRAVELER (Set to 1 if the character is a traveler)
										// JO_JOIN_Wannabe (If set to 1 the NPC is available to be a traveler Can be changed in PID)
// Note :
	// First time from party to familiar
		 // Add script GENERAL JO_JOINI
			// Display "We are now fellow travelers"
///////////////////////////////////////////////////////////////////////////////

// Main Traveler 1

IF // ChangeEnemyAlly(Myself,FAMILIAR)
	Global("JO_JOIN","LOCALS",1)
	Allegiance(Myself,PC)
	!InPartySlot(Myself,0)
	OR(2)
		Global("JO_JOIN_FAMILIAR","LOCALS",1)
		!Global("JO_JOIN_CONTROLLED","LOCALS",1)
THEN
	RESPONSE #100
		SetInterrupt(FALSE)
		MakeGlobalOverride()
		LeaveParty()
		SmallWait(1)
		GiveItemCreate("JOMINHP1",Myself,0,0,0)
		SmallWait(1)
		EquipItemEx("JOMINHP1",0)
		SmallWait(1)
		ChangeEnemyAlly(Myself,FAMILIAR)
		AddFamiliar()
		FaceObject(Player1)
//
		SetGlobal("JO_JOIN_TALK","LOCALS",1) // Display "We are now fellow travelers"
		SetGlobal("JO_JOIN","LOCALS",2)
//
		SetGlobalTimer("JO_JOIN_SWITCH_TIMER","LOCALS",ONE_DAY)
//
		SetGlobal("JO_JOIN_IS_TRAVELER","LOCALS",1)
		SetGlobal("JO_JOIN_Wannabe","LOCALS",1)
//
		SetGlobal("JO_JOIN_NEVER_JOIN","LOCALS",0)
		SetGlobal("JO_JOIN_NEVER_SWITCH","LOCALS",0)
		SetGlobal("JO_JOIN_NEVER_BANTER","LOCALS",0)
//		SetGlobalTimer("JO_JOIN_JOIN_TIMER","LOCALS",ONE_TURN) // Moved in Jo_Joini to facilitate componant Traveler Quick Switch Timer
		ChangeAIScript("JO_JOINI",GENERAL)
		SetInterrupt(TRUE)
		Continue()
END

IF // ChangeEnemyAlly(Myself,CONTROLLED)
	Global("JO_JOIN","LOCALS",1)
	Allegiance(Myself,PC)
	!InPartySlot(Myself,0)
	Global("JO_JOIN_CONTROLLED","LOCALS",1)
THEN
	RESPONSE #100
		SetInterrupt(FALSE)
		MakeGlobalOverride()
		LeaveParty()
		SmallWait(1)
		GiveItemCreate("JOMINHP1",Myself,0,0,0)
		SmallWait(1)
		EquipItemEx("JOMINHP1",0)
		SmallWait(1)
		ChangeEnemyAlly(Myself,CONTROLLED)
		AddFamiliar()
		FaceObject(Player1)
		SetGlobal("JO_JOIN_TALK","LOCALS",1) // Display "We are now fellow travelers"
		SetGlobal("JO_JOIN","LOCALS",2)
		SetGlobalTimer("JO_JOIN_SWITCH_TIMER","LOCALS",ONE_DAY)
		SetGlobal("JO_JOIN_IS_TRAVELER","LOCALS",1)
		SetGlobal("JO_JOIN_Wannabe","LOCALS",1)
		SetGlobal("JO_JOIN_NEVER_JOIN","LOCALS",0)
		SetGlobal("JO_JOIN_NEVER_SWITCH","LOCALS",0)
		SetGlobal("JO_JOIN_NEVER_BANTER","LOCALS",0)
		ChangeAIScript("JO_JOINI",GENERAL)
		SetInterrupt(TRUE)
		Continue()
END

// fellow travelers (End first time from party to familiar)

// Secondary Traveler 1

IF
	Global("JO_JOIN_TALK","LOCALS",1)
	OR(3)
		Allegiance(Myself,FAMILIAR)
		Allegiance(Myself,CONTROLLED)
		!Global("JO_JOIN_IS_TRAVELER","LOCALS",0)
THEN
	RESPONSE #100
		SetGlobal("JO_JOIN_TALK","LOCALS",0)
		SetGlobal("JO_TRAVELER_%Death_var%","GLOBAL",1)
		DisplayStringHead(Myself,~We are now fellow travelers.~)
		Continue() // To relevant JO_JOIN... blocks
END


///////////////////////////////////////////////////////////////////////////////

// Quick Switch

///////////////////////////////////////////////////////////////////////////////
// Variables : :
	// JO_JOIN_JOIN_TIMER (Set when a party member become a traveler or when a traveler do a quick switch)
		// JO_JOIN_FORCE_SWITCH (Set by PID)
			// JO_JOINI (Set in JO_JOINI.baf when a traveler is in party for a Quick Switch)
// Note :
	// Switch between familiar and party
		// Also used by Loading Party
///////////////////////////////////////////////////////////////////////////////

// Main Quick Switch 4 (Previous are in JO_JOINI.baf)

IF // ChangeEnemyAlly(Myself,FAMILIAR)
	Global("JO_JOINI","LOCALS",1)
	Allegiance(Myself,PC)
	!InPartySlot(Myself,0)
	OR(2)
		Global("JO_JOIN_FAMILIAR","LOCALS",1)
		!Global("JO_JOIN_CONTROLLED","LOCALS",1)
//
	OR(2)
		GlobalGT("JO_JOIN_LOADING","GLOBAL",0) // No delay when travelers switch at loading
		Delay(6)
THEN
	RESPONSE #100
		SetInterrupt(FALSE)
		LeaveParty()
		SetGlobal("JO_NOJOIN","GLOBAL",0)
		SetGlobal("JO_NOJOIN_LOCALS","LOCALS",0)
		SmallWait(1)
		GiveItemCreate("JOMINHP1",Myself,0,0,0)
		SmallWait(1)
		EquipItemEx("JOMINHP1",0)
		SmallWait(1)
		ChangeEnemyAlly(Myself,FAMILIAR)
		AddFamiliar()
		SmallWait(1)
//
		SetGlobalTimer("JO_JOIN_SWITCH_TIMER","LOCALS",ONE_DAY) // TODO: Added // Related to Switching party in JO_JOINI and JO_JOIN_Wannabe in All_in
//
		SetGlobal("JO_JOIN_IS_TRAVELER","LOCALS",1)
		SetGlobal("JO_JOINI","LOCALS",0)
//
		SetGlobal("JO_JOIN","LOCALS",2)
//
		SetGlobal("JO_JOIN_FORCE_SWITCH","LOCALS",0)
//
// Add switch familiar related  script
//		ChangeAIScript("",RACE)
//		ChangeAIScript("",CLASS)
//		ChangeAIScript("",GENERAL)
		ChangeAIScript("JO_JOINI",GENERAL)
		SetInterrupt(TRUE)
		Face(S)
		Continue() // To relevant JO_JOIN... blocks
END

IF // ChangeEnemyAlly(Myself,CONTROLLED)
	Global("JO_JOINI","LOCALS",1)
	Allegiance(Myself,PC)
	!InPartySlot(Myself,0)
	Global("JO_JOIN_CONTROLLED","LOCALS",1)
//
	OR(2)
		GlobalGT("JO_JOIN_LOADING","GLOBAL",0) // No delay when travelers switch at loading
		Delay(6)
THEN
	RESPONSE #100
		SetInterrupt(FALSE)
		LeaveParty()
		SetGlobal("JO_NOJOIN","GLOBAL",0)
		SetGlobal("JO_NOJOIN_LOCALS","LOCALS",0)
		SmallWait(1)
		GiveItemCreate("JOMINHP1",Myself,0,0,0)
		SmallWait(1)
		EquipItemEx("JOMINHP1",0)
		SmallWait(1)
		ChangeEnemyAlly(Myself,CONTROLLED)
		AddFamiliar()
		SmallWait(1)
 // Related to Switching party in JO_JOINI and JO_JOIN_Wannabe in All_in
		SetGlobalTimer("JO_JOIN_SWITCH_TIMER","LOCALS",ONE_DAY)
		SetGlobal("JO_JOIN_IS_TRAVELER","LOCALS",1)
		SetGlobal("JO_JOINI","LOCALS",0)
		SetGlobal("JO_JOIN","LOCALS",2)
		SetGlobal("JO_JOIN_FORCE_SWITCH","LOCALS",0)
		ChangeAIScript("JO_JOINI",GENERAL)
		SetInterrupt(TRUE)
		Face(S)
		Continue() // To relevant JO_JOIN... blocks
END

