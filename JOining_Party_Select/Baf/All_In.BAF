///////////////////////////////////////////////////////////////////////////////

// LeaveParty for travelers

///////////////////////////////////////////////////////////////////////////////

// 1 // If party is full, randomely pick one member / Wannabe to make room an instant

IF
// Main triggers
	Global("JO_JOIN_LOADING","GLOBAL",0) // Don't use this block at loading
//
	NumInPartyGT(5)
	OR(2)
		!Global("JO_Myself_LeaveParty","LOCALS",0)
		!Global("JO_%Death_var%_LeaveParty","GLOBAL",0)
//
	!Global("JO_Myself_Valid","LOCALS",0)
	OR(2)
		Allegiance(Myself,FAMILIAR)
		!Global("JO_JOIN_IS_TRAVELER","LOCALS",0)
//
	!TriggerOverride(Player2,Global("JO_JOIN_Wannabe","LOCALS",0))
	!TriggerOverride(Player2,Global("JO_Myself_Valid","LOCALS",0))
	RandomNum(5,1)
THEN
	RESPONSE #100
		SetInterrupt(FALSE)
		ActionOverride(Player2,SetGlobal("JO_JOIN_LOAD_PARTY","LOCALS",1)) // Make actual party member jump to block 2 in Loading Party members
		SetGlobal("JO_JOIN_PARTY_SWITCH","GLOBAL",1) // Make actual party member jump to block 2 in Loading Party members
		SetInterrupt(TRUE)
		Continue()
END

IF
// Main triggers
	Global("JO_JOIN_LOADING","GLOBAL",0) // Don't use this block at loading
//
	NumInPartyGT(5)
	OR(2)
		!Global("JO_Myself_LeaveParty","LOCALS",0)
		!Global("JO_%Death_var%_LeaveParty","GLOBAL",0)
//
	!Global("JO_Myself_Valid","LOCALS",0)
	OR(2)
		Allegiance(Myself,FAMILIAR)
		!Global("JO_JOIN_IS_TRAVELER","LOCALS",0)
//
	!TriggerOverride(Player3,Global("JO_JOIN_Wannabe","LOCALS",0))
	!TriggerOverride(Player3,Global("JO_Myself_Valid","LOCALS",0))
	RandomNum(5,2)
THEN
	RESPONSE #100
		SetInterrupt(FALSE)
		ActionOverride(Player3,SetGlobal("JO_JOIN_LOAD_PARTY","LOCALS",1))
		SetGlobal("JO_JOIN_PARTY_SWITCH","GLOBAL",1)
		SetInterrupt(TRUE)
		Continue()
END

IF
// Main triggers
	Global("JO_JOIN_LOADING","GLOBAL",0) // Don't use this block at loading
//
	NumInPartyGT(5)
	OR(2)
		!Global("JO_Myself_LeaveParty","LOCALS",0)
		!Global("JO_%Death_var%_LeaveParty","GLOBAL",0)
//
	!Global("JO_Myself_Valid","LOCALS",0)
	OR(2)
		Allegiance(Myself,FAMILIAR)
		!Global("JO_JOIN_IS_TRAVELER","LOCALS",0)
//
	!TriggerOverride(Player4,Global("JO_JOIN_Wannabe","LOCALS",0))
	!TriggerOverride(Player4,Global("JO_Myself_Valid","LOCALS",0))
	RandomNum(5,2)
THEN
	RESPONSE #100
		SetInterrupt(FALSE)
		ActionOverride(Player4,SetGlobal("JO_JOIN_LOAD_PARTY","LOCALS",1))
		SetGlobal("JO_JOIN_PARTY_SWITCH","GLOBAL",1)
		SetInterrupt(TRUE)
		Continue()
END

IF
// Main triggers
	Global("JO_JOIN_LOADING","GLOBAL",0) // Don't use this block at loading
//
	NumInPartyGT(5)
	OR(2)
		!Global("JO_Myself_LeaveParty","LOCALS",0)
		!Global("JO_%Death_var%_LeaveParty","GLOBAL",0)
//
	!Global("JO_Myself_Valid","LOCALS",0)
	OR(2)
		Allegiance(Myself,FAMILIAR)
		!Global("JO_JOIN_IS_TRAVELER","LOCALS",0)
//
	!TriggerOverride(Player5,Global("JO_JOIN_Wannabe","LOCALS",0))
	!TriggerOverride(Player5,Global("JO_Myself_Valid","LOCALS",0))
	RandomNum(5,2)
THEN
	RESPONSE #100
		SetInterrupt(FALSE)
		ActionOverride(Player5,SetGlobal("JO_JOIN_LOAD_PARTY","LOCALS",1))
		SetGlobal("JO_JOIN_PARTY_SWITCH","GLOBAL",1)
		SetInterrupt(TRUE)
		Continue()
END

IF
// Main triggers
	Global("JO_JOIN_LOADING","GLOBAL",0) // Don't use this block at loading
//
	NumInPartyGT(5)
	OR(2)
		!Global("JO_Myself_LeaveParty","LOCALS",0)
		!Global("JO_%Death_var%_LeaveParty","GLOBAL",0)
//
	!Global("JO_Myself_Valid","LOCALS",0)
	OR(2)
		Allegiance(Myself,FAMILIAR)
		!Global("JO_JOIN_IS_TRAVELER","LOCALS",0)
//
	!TriggerOverride(Player6,Global("JO_JOIN_Wannabe","LOCALS",0))
	!TriggerOverride(Player6,Global("JO_Myself_Valid","LOCALS",0))
	RandomNum(5,2)
THEN
	RESPONSE #100
		SetInterrupt(FALSE)
		ActionOverride(Player6,SetGlobal("JO_JOIN_LOAD_PARTY","LOCALS",1))
		SetGlobal("JO_JOIN_PARTY_SWITCH","GLOBAL",1)
		SetInterrupt(TRUE)
		Continue()
END

// 2 // If / when party isn't full, come in party

IF
// Main triggers
	Global("JO_JOIN_LOADING","GLOBAL",0) // Don't use this block at loading
//
	NumInPartyLT(6)
	OR(2)
		!Global("JO_Myself_LeaveParty","LOCALS",0)
		!Global("JO_%Death_var%_LeaveParty","GLOBAL",0)
	!Global("JO_Myself_Valid","LOCALS",0)
	OR(2)
		Allegiance(Myself,FAMILIAR)
		!Global("JO_JOIN_IS_TRAVELER","LOCALS",0)
THEN
	RESPONSE #100
		SetInterrupt(FALSE)
		SetGlobal("JO_JOIN_NEVER_JOIN","LOCALS",0)
		SetGlobal("JO_JOIN_NEVER_SWITCH","LOCALS",0)
		SetGlobal("JO_TRAVELER_%Death_var%","GLOBAL",0)
		SetGlobal("JO_JOIN_IS_TRAVELER","LOCALS",0)
		SetGlobal("JO_JOIN_IS_JOINING","LOCALS",0)
		SetGlobal("JO_JOIN","LOCALS",0)
		SetGlobal("JO_JOINI","LOCALS",0)
		SetGlobal("JO_JOIN_Move_Done","LOCALS",0)
		SmallWait(1)
		EquipItemEx("JOMINHP1",1) 
		SmallWait(1)
		DestroyItem("JOMINHP1")
		SmallWait(1)
		SetInterrupt(TRUE)
		JoinPartyOverride()
END

// 3 // Then leave party the regular way.

IF
// Main triggers
	Global("JO_JOIN_LOADING","GLOBAL",0) // Don't use this block at loading
//
	OR(2)
		!Global("JO_Myself_LeaveParty","LOCALS",0)
		!Global("JO_%Death_var%_LeaveParty","GLOBAL",0)
	Allegiance(Myself,PC)
	!InPartySlot(Myself,0)
THEN
	RESPONSE #100
		SetInterrupt(FALSE)
		SetGlobal("JO_Myself_LeaveParty","LOCALS",0)
		SetGlobal("JO_%Death_var%_LeaveParty","GLOBAL",0)
		SetGlobal("JO_Myself_AllowDead","LOCALS",0)
		SetGlobal("JO_Myself_InParty","LOCALS",0)
		SetGlobal("JO_Myself_Valid","LOCALS",0)
		MakeGlobal()
		DisplayStringHead(Myself,~Farewell...~)
		MakeGlobalOverride() 
		LeaveParty()
		SetInterrupt(TRUE)
END

