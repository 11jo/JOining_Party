///////////////////////////////////////////////////////////////////////////////

// Loading Switch

///////////////////////////////////////////////////////////////////////////////
// Variables
	// JO_JOIN_LOADING (Launch Loading Switch script/CutSceneLite)
		// JO_JOIN_LOADING_PLAYER (Check if a least one traveler is present)
///////////////////////////////////////////////////////////////////////////////

IF
// Main triggers
	InParty(Myself)
	!Dead("%Death_var%")
	Global("JO_JOIN_LOADING_PLAYER","LOCALS",0)
// Secondary triggers
	Global("JO_JOIN_LOADING","GLOBAL",1)
	NumInParty(6)
	Global("JO_JOINI","LOCALS",1)
THEN
	RESPONSE #100 
		SetInterrupt(FALSE)
		SetGlobal("JO_JOIN_LOADING_PLAYER","LOCALS",1)
		DisplayStringHead(Myself,~Oh no ! More Travelers...~)
		LeaveParty()
		SmallWait(1)
		Deactivate(Myself)
		SetInterrupt(TRUE)
END

IF
// Main triggers
	Global("JO_JOIN_LOADING_PLAYER","LOCALS",1)
	Global("JO_JOIN_LOADING","GLOBAL",0)
// Secondary triggers
	NumInPartyLT(6)
THEN
	RESPONSE #100
		SetInterrupt(FALSE)
		SetGlobal("JO_JOIN_LOADING_PLAYER","LOCALS",0)
		Activate(Myself)
		SmallWait(1)
		DisplayStringHead(Myself,~I'm back !~)
		SetInterrupt(TRUE)
		JoinParty()
END

IF
	Global("JO_JOIN_LOAD","LOCALS",3)
	Global("JO_JOIN_LOADING","GLOBAL",0)
THEN
	RESPONSE #100
		SetGlobal("JO_JOIN_LOAD","LOCALS",0)
END

//  See LeaveParty for travelers to rethink

IF
	InParty(Myself)
	!InPartySlot(Myself,0)
//
	Global("JO_JOIN_LOAD_PARTY","LOCALS",1)
THEN
	RESPONSE #100
		SetInterrupt(FALSE)
		MakeGlobalOverride() 
		LeaveParty()
		SmallWait(1)
		GiveItemCreate("JOMINHP1",Myself,0,0,0)
//		SmallWait(1)
		EquipItemEx("JOMINHP1",0)
//		SmallWait(1)
		ChangeEnemyAlly(Myself,FAMILIAR)
		AddFamiliar()
		FaceObject(Player1)
		SetGlobal("JO_TRAVELER_%Death_var%","GLOBAL",1)
		SetGlobal("JO_JOIN_IS_TRAVELER","LOCALS",1)
		DisplayStringHead(Myself,~Oh no ! more travelers~)
		MoveToOffset([0.1])
		ChangeAIScript("JO_JOINI",GENERAL)
		SetInterrupt(TRUE)
END

///////////////////////////////////////////////////////////////////////////////

//////////////// JO_JOIN_Fill_Party

///////////////////////////////////////////////////////////////////////////////

// If free party slots then some travelers can join the group
// Launched by JOJOINNE.d, JO_JOIN_Move_Around 15 


IF
// Main triggers
	Global("JO_JOIN_LOADING","GLOBAL",0) // Don't use this block at loading
//
	InParty(Myself)
	!Global("JO_JOIN_Fill_Party","LOCALS",0)
THEN
	RESPONSE #100
		SetInterrupt(FALSE)
		SetGlobal("JO_JOIN_IS_JOINING","LOCALS",0)
		SetGlobal("JO_JOIN_Fill_Party","LOCALS",0)
		SetInterrupt(TRUE)
		Continue()
END

///////////////////////////////////////////////////////////////////////////////

//////////////// JO_JOIN_Wannabe : NPC can be traveler

///////////////////////////////////////////////////////////////////////////////
// A party member available to be traveler

// Related to JO_JOIN_PARTY_SWITCH / JO_JOIN_LOAD_PARTY

IF
	Global("JO_JOIN_Wannabe","LOCALS",0)
	InParty(Myself)
	Global("JO_JOIN_IS_Wannabe","LOCALS",0) // Only once
THEN
	RESPONSE #100
		SetGlobal("JO_JOIN_IS_Wannabe","LOCALS",1)
		SetGlobal("JO_JOIN_Wannabe","LOCALS",1)
		SetGlobalTimer("JO_JOIN_SWITCH_TIMER","LOCALS",ONE_DAY)
		Continue()
END

