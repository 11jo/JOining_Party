		ActionOverride(PartySlot3,SetGlobal("JO_JOIN_RETURN_MYSLOT","LOCALS",4))
		ActionOverride(PartySlot3,IncrementGlobal("JO_JOIN_RETURN_SLOT","GLOBAL",1))
		ActionOverride(PartySlot3,SetGlobal("JO_JOIN_SLOTNUMBER","GLOBAL",4))  // Will reintegre place 4 / Go to relevant block in All_in.baf
		SmallWait(3)
		ActionOverride(PartySlot3,LeaveParty())
		ActionOverride(PartySlot3,Deactivate(Myself))
//
		ActionOverride(PartySlot2,SetGlobal("JO_JOIN_RETURNSLOT_WAIT","LOCALS",0))
		ActionOverride(PartySlot2,SetGlobal("JO_JOIN_RETURN_MYSLOT","LOCALS",3))
		ActionOverride(PartySlot2,IncrementGlobal("JO_JOIN_RETURN_SLOT","GLOBAL",1))
		ActionOverride(PartySlot2,SetGlobal("JO_JOIN_SLOTNUMBER","GLOBAL",3))  // Will reintegre place 3 / Go to relevant block in All_in.baf
		SmallWait(3)
		ActionOverride(PartySlot2,LeaveParty())
		ActionOverride(PartySlot2,Deactivate(Myself))
//
		SetGlobal("JO_JOIN_NEVER_JOIN","LOCALS",0)
		SetGlobal("JO_JOIN","LOCALS",0)
		SetGlobal("JO_JOIN_IS_TRAVELER","LOCALS",0)
		SetGlobal("JO_JOIN_SWITCH_WAIT","LOCALS",0)
		SmallWait(2)
		EquipItemEx("JOMINHP1",1)
		SmallWait(1)
		DestroyItem("JOMINHP1")
		SmallWait(1)
		SetInterrupt(TRUE)
		JoinParty()
	RESPONSE #3 // PartySlot3
		SetInterrupt(FALSE)
		DisplayStringHead(Myself,~My turn !~)
