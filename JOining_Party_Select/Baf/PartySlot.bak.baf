		ActionOverride(PartySlot5,IncrementGlobal("JO_JOIN_RETURN_SLOT","GLOBAL",1))
		ActionOverride(PartySlot5,SetGlobal("JO_JOIN_SLOTNUMBER","GLOBAL",6))  // Will reintegre place 6 / Go to relevant block in All_in.baf
		SmallWait(3)
		ActionOverride(PartySlot5,LeaveParty())
		ActionOverride(PartySlot5,Deactivate(Myself)) // If exist will make place for an instant
//
