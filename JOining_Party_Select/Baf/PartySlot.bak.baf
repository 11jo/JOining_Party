// SP 5.1 // Secondary Switching Party 3 // If something prevent the traveler to Join

IF // Reset variable for traveler
//
	Delay(10) // Prevent to be checked before Playerx leave the party
//
	GlobalGT("JO_JOIN_READY_TO_SWITCH","LOCALS",1)
	!Global("JO_JOIN_SWITCH_WITH_ME","LOCALS",0)
//
	OR(3)
		Allegiance(Myself,FAMILIAR)
		Allegiance(Myself,CONTROLLED)
		!Global("JO_JOIN_IS_TRAVELER","LOCALS",0)
//
	NumInPartyGT(5)
THEN
	RESPONSE #100
		SetGlobal("JO_JOIN_SWITCH_WITH_ME","LOCALS",0)
		SetGlobal("JO_JOIN_NEVER_SWITCH","LOCALS",0)
		SetGlobal("JO_JOIN_READY_TO_SWITCH","LOCALS",11)
		Continue()
END