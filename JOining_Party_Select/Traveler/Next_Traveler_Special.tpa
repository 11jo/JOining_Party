/////////////////////////// JOining_Party_Select_Core_Original.tph ///////////////////////////

ACTION_IF Traveler_Continuous = 1 THEN BEGIN

OUTER_SPRINT Select_Core_Original = 0

		COPY ~JOining_Party_Select/Lib/JOining_Party_Select_Core_Original.tph~	~JOining_Party_Select/Lib/JOining_Party_Select_Core_Original.tph~
			REPLACE_TEXTUALLY ~// Next_Traveler Continuous~ ~~~~~// %NEW_TRAVELER_MOD_NAME%

    PATCH_IF NOT (~%NEW_TRAVELER_OVERRIDE_SCRIPT_NAME_BG1%~ STRING_EQUAL_CASE ~~) AND (~%NEW_TRAVELER_OVERRIDE_SCRIPT_NAME_SoD%~ STRING_EQUAL_CASE ~~) BEGIN

OUTER_SPRINT Select_Core_Original = 1

OUTER_SPRINT "BG1_JOINED" "%NEW_TRAVELER_JOINING_DIALOG_NAME_BG1%"
OUTER_SPRINT "BG1_BCS" "%NEW_TRAVELER_OVERRIDE_SCRIPT_NAME_BG1%"
OUTER_SPRINT "SoD_JOINED" "%NEW_TRAVELER_JOINING_DIALOG_NAME_BG1%"
OUTER_SPRINT "SoD_BCS" "%NEW_TRAVELER_OVERRIDE_SCRIPT_NAME_BG1%"
OUTER_SPRINT "BG1_BANTER" "%NEW_TRAVELER_REGULAR_BANTER_NAME_BG1%"
OUTER_SPRINT "SoD_BANTER" "%NEW_TRAVELER_REGULAR_BANTER_NAME_BG1%"
OUTER_SPRINT "BG1_DREAM" "%NEW_TRAVELER_DREAM_BANTER_NAME_BG1%"
OUTER_SPRINT "SoD_DREAM" "%NEW_TRAVELER_DREAM_BANTER_NAME_BG1%"

	END

    PATCH_IF NOT (~%NEW_TRAVELER_OVERRIDE_SCRIPT_NAME_BG1%~ STRING_EQUAL_CASE ~~) AND NOT (~%NEW_TRAVELER_OVERRIDE_SCRIPT_NAME_SoD%~ STRING_EQUAL_CASE ~~) BEGIN

OUTER_SPRINT Select_Core_Original = 2

OUTER_SPRINT "BG1_JOINED" "%NEW_TRAVELER_JOINING_DIALOG_NAME_BG1%"
OUTER_SPRINT "BG1_BCS" "%NEW_TRAVELER_OVERRIDE_SCRIPT_NAME_BG1%"
ACTION_IF (GAME_IS ~eet~) BEGIN
OUTER_SPRINT "SoD_JOINED" "%NEW_TRAVELER_JOINING_DIALOG_NAME_BG1%"
END ELSE BEGIN
OUTER_SPRINT "SoD_JOINED" "%NEW_TRAVELER_JOINING_DIALOG_NAME_SoD%"
END
OUTER_SPRINT "SoD_BCS" "%NEW_TRAVELER_OVERRIDE_SCRIPT_NAME_SoD%"
OUTER_SPRINT "BG1_BANTER" "%NEW_TRAVELER_REGULAR_BANTER_NAME_BG1%"
OUTER_SPRINT "SoD_BANTER" "%NEW_TRAVELER_DREAM_BANTER_NAME_SoD"
OUTER_SPRINT "BG1_DREAM" "%NEW_TRAVELER_DREAM_BANTER_NAME_BG1%"
OUTER_SPRINT "SoD_DREAM" "%NEW_TRAVELER_DREAM_BANTER_NAME_SoD%"

	END

    PATCH_IF NOT (~%NEW_TRAVELER_OVERRIDE_SCRIPT_NAME_BG2%~ STRING_EQUAL_CASE ~~) AND (~%NEW_TRAVELER_OVERRIDE_SCRIPT_NAME_ToB%~ STRING_EQUAL_CASE ~~) BEGIN

OUTER_SPRINT Select_Core_Original = 3

OUTER_SPRINT "BG2_JOINED" "%NEW_TRAVELER_JOINING_DIALOG_NAME_BG2%"
OUTER_SPRINT "BG2_BCS" "%NEW_TRAVELER_OVERRIDE_SCRIPT_NAME_BG2%"
OUTER_SPRINT "TOB_JOINED" "%NEW_TRAVELER_JOINING_DIALOG_NAME_BG2%"
OUTER_SPRINT "TOB_BCS" "%NEW_TRAVELER_OVERRIDE_SCRIPT_NAME_BG2%"
OUTER_SPRINT "BG2_BANTER" "%NEW_TRAVELER_REGULAR_BANTER_NAME_BG2%"
OUTER_SPRINT "TOB_BANTER" "%NEW_TRAVELER_REGULAR_BANTER_NAME_BG2%"
OUTER_SPRINT "BG2_DREAM" "%NEW_TRAVELER_DREAM_BANTER_NAME_BG2%"
OUTER_SPRINT "TOB_DREAM" "%NEW_TRAVELER_DREAM_BANTER_NAME_BG2%"

	END

    PATCH_IF NOT (~%NEW_TRAVELER_OVERRIDE_SCRIPT_NAME_BG2%~ STRING_EQUAL_CASE ~~) AND NOT (~%NEW_TRAVELER_OVERRIDE_SCRIPT_NAME_ToB%~ STRING_EQUAL_CASE ~~) BEGIN

OUTER_SPRINT Select_Core_Original = 4

OUTER_SPRINT "BG2_JOINED" "%NEW_TRAVELER_JOINING_DIALOG_NAME_BG2%"
OUTER_SPRINT "BG2_BCS" "%NEW_TRAVELER_OVERRIDE_SCRIPT_NAME_BG2%"
OUTER_SPRINT "BG2_BANTER" "%NEW_TRAVELER_REGULAR_BANTER_NAME_BG2%"
OUTER_SPRINT "BG2_DREAM" "%NEW_TRAVELER_DREAM_BANTER_NAME_BG2%"
ACTION_IF (GAME_IS ~eet~) BEGIN
OUTER_SPRINT "TOB_JOINED" "%NEW_TRAVELER_JOINING_DIALOG_NAME_BG2%"
OUTER_SPRINT "TOB_BANTER" "%NEW_TRAVELER_REGULAR_BANTER_NAME_BG2%"
OUTER_SPRINT "TOB_DREAM" "%NEW_TRAVELER_DREAM_BANTER_NAME_BG2%"
END ELSE BEGIN
OUTER_SPRINT "TOB_JOINED" "%NEW_TRAVELER_JOINING_DIALOG_NAME_ToB%"
OUTER_SPRINT "TOB_BANTER" "%NEW_TRAVELER_REGULAR_BANTER_NAME_TOB%"
OUTER_SPRINT "TOB_DREAM" "%NEW_TRAVELER_DREAM_BANTER_NAME_TOB%"
END
OUTER_SPRINT "TOB_BCS" "%NEW_TRAVELER_OVERRIDE_SCRIPT_NAME_ToB%"

	END


ACTION_FOR_EACH bcs IN

// Mod %NEW_TRAVELER_NAME% ACTION_IF Select_Core_Original_BG1 = 1 BEGIN ~%NEW_TRAVELER_OVERRIDE_SCRIPT_NAME_BG1%~ END ACTION_IF Select_Core_Original_BG2 = 1 BEGIN ~%NEW_TRAVELER_OVERRIDE_SCRIPT_NAME_SoD%~ END ACTION_IF Select_Core_Original_ToB = 1 BEGIN ~%NEW_TRAVELER_OVERRIDE_SCRIPT_NAME_BG2%~ END ACTION_IF Select_Core_Original_BG1 = 1 BEGIN ~%NEW_TRAVELER_OVERRIDE_SCRIPT_NAME_ToB%~ END

BEGIN

	ACTION_IF FILE_EXISTS_IN_GAME ~%bcs%.bcs~ BEGIN

				EXTEND_TOP ~%bcs%.bcs~ ~JOining_Party_Select/Baf/All_TRAVELER_JOIN.baf~

		EXTEND_BOTTOM ~%bcs%.bcs~ ~weidu_external/JOining_Party_Select/All_In/%NEW_TRAVELER_DeathVar%_All_In.baf~ EVALUATE_BUFFER

		INCLUDE ~JOining_Party_Select/Baf/JO_JOIN/JO_JOIN_Continuous.tpa~

		EXTEND_BOTTOM ~%bcs%.bcs~ ~JOining_Party_Select/Baf/JO_JOIN/JO_JOIN.BAF~ EVALUATE_BUFFER

						ACTION_IF (GAME_IS ~eet~) BEGIN
		EXTEND_BOTTOM ~%bcs%.bcs~ ~JOining_Party_Select/Baf/Banter_Continuous.baf~ EVALUATE_BUFFER
						END ELSE ACTION_IF (GAME_INCLUDES ~SoD~ AND NOT GAME_IS ~eet~) BEGIN
		EXTEND_BOTTOM ~%bcs%.bcs~ ~JOining_Party_Select/Baf/Banter_BGSoD.baf~ EVALUATE_BUFFER
						END ELSE ACTION_IF (GAME_IS ~bgee~ AND NOT GAME_INCLUDES ~SoD~) BEGIN
		EXTEND_BOTTOM ~%bcs%.bcs~ ~JOining_Party_Select/Baf/Banter_BG1.baf~ EVALUATE_BUFFER
						END ELSE ACTION_IF (GAME_IS ~bg2ee~ AND NOT GAME_IS ~eet~) BEGIN
		EXTEND_BOTTOM ~%bcs%.bcs~ ~JOining_Party_Select/Baf/Banter_BG2.baf~ EVALUATE_BUFFER
						END


	END
END

// Next_Traveler Continuous~~~~~

	END

END
